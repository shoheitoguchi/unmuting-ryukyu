---
import LayoutEN from '../../layouts/LayoutEN.astro';
---

<LayoutEN title="Shohei Toguchi | Documentary Filmmaker & Video Editor — Okinawa">

  <!-- ── HERO: Norikura-style full-width carousel ── -->
  <section style="position:relative;min-height:100vh;display:flex;align-items:center;overflow:hidden;">

    <!-- Carousel slides -->
    <div style="position:absolute;inset:0;z-index:0;">
      <div style="position:absolute;inset:0;background-image:url('/images/shuri-castle.jpg');background-size:cover;background-position:center;opacity:0;animation:heroSlide 18s 0s infinite;"></div>
      <div style="position:absolute;inset:0;background-image:url('/images/shuri-castle.jpg');background-size:cover;background-position:top;filter:hue-rotate(8deg) brightness(0.9);opacity:0;animation:heroSlide 18s 6s infinite;"></div>
      <div style="position:absolute;inset:0;background-image:url('/images/shuri-castle.jpg');background-size:cover;background-position:bottom;filter:saturate(1.1) brightness(0.85);opacity:0;animation:heroSlide 18s 12s infinite;"></div>
    </div>

    <!-- Overlay: lighter than gate for readability -->
    <div style="position:absolute;inset:0;z-index:1;background:linear-gradient(105deg, rgba(26,58,74,0.82) 0%, rgba(26,58,74,0.55) 55%, rgba(11,27,38,0.72) 100%);"></div>

    <!-- Water-blue left bar -->
    <div style="position:absolute;top:0;left:0;width:5px;height:100%;z-index:2;background:linear-gradient(to bottom,transparent,#7EC8E3 30%,#5BAAC8 70%,transparent);"></div>

    <!-- Content -->
    <div style="position:relative;z-index:3;max-width:1200px;margin:0 auto;padding:120px 40px 80px;width:100%;">
      <p style="font-family:'DM Sans',sans-serif;font-size:11px;font-weight:700;letter-spacing:0.35em;text-transform:uppercase;color:#7EC8E3;margin:0 0 32px 0;">Documentary Filmmaker · Video Editor · Cultural Storyteller</p>

      <h1 style="font-family:'DM Sans',sans-serif;font-size:clamp(56px,9vw,112px);font-weight:900;line-height:0.9;letter-spacing:-0.03em;color:#F5FAFB;margin:0 0 12px 0;text-transform:uppercase;">
        SHOHEI<br/>
        <span style="color:#7EC8E3;">TOGUCHI</span>
      </h1>

      <div style="width:56px;height:3px;background:#7EC8E3;margin:40px 0;"></div>

      <p style="font-family:'Inter',sans-serif;font-size:clamp(16px,2vw,20px);color:rgba(245,250,251,0.78);line-height:1.75;max-width:520px;margin:0 0 60px 0;">
        Revealing the hidden stories of Okinawa's struggle, culture, and resilience — for English, Chinese, and Japanese audiences worldwide.
      </p>

      <div style="display:flex;gap:16px;flex-wrap:wrap;">
        <a href="/en/portfolio/" style="text-decoration:none;display:inline-flex;align-items:center;gap:10px;background:#7EC8E3;color:#1A3A4A;font-family:'DM Sans',sans-serif;font-weight:700;font-size:14px;letter-spacing:0.05em;padding:16px 36px;border-radius:4px;text-transform:uppercase;transition:background 0.2s;">
          View Portfolio →
        </a>
        <a href="https://www.youtube.com/@letsgokinawa" target="_blank" rel="noopener" style="text-decoration:none;display:inline-flex;align-items:center;gap:10px;border:1px solid rgba(126,200,227,0.4);color:#F5FAFB;font-family:'DM Sans',sans-serif;font-weight:500;font-size:14px;letter-spacing:0.02em;padding:16px 36px;border-radius:4px;backdrop-filter:blur(4px);">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          Watch on YouTube
        </a>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div style="position:absolute;bottom:40px;left:50%;transform:translateX(-50%);z-index:3;display:flex;flex-direction:column;align-items:center;gap:8px;opacity:0.45;">
      <span style="font-family:'DM Sans',sans-serif;font-size:10px;letter-spacing:0.2em;text-transform:uppercase;color:#7EC8E3;">Scroll</span>
      <div style="width:1px;height:40px;background:linear-gradient(to bottom,#7EC8E3,transparent);"></div>
    </div>
  </section>

  <style>
    @keyframes heroSlide {
      0%        { opacity:0; transform:scale(1.06); }
      5%        { opacity:1; transform:scale(1.03); }
      28%       { opacity:1; transform:scale(1.00); }
      36%,100%  { opacity:0; transform:scale(0.97); }
    }
  </style>

  <!-- ── WHO I AM ── -->
  <section style="padding:120px 40px;background:#FFFFFF;">
    <div style="max-width:1100px;margin:0 auto;display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:80px;align-items:center;">
      <div>
        <p style="font-family:'DM Sans',sans-serif;font-size:11px;font-weight:700;letter-spacing:0.3em;text-transform:uppercase;color:#7EC8E3;margin:0 0 20px 0;">Who I Am</p>
        <h2 style="font-family:'DM Sans',sans-serif;font-size:clamp(32px,5vw,52px);font-weight:800;color:#1A3A4A;margin:0 0 32px 0;line-height:1.05;letter-spacing:-0.02em;">Video Editor &amp;<br/>Documentary Filmmaker</h2>
        <div style="width:48px;height:3px;background:#7EC8E3;margin-bottom:32px;"></div>
        <p style="font-family:'Inter',sans-serif;font-size:16px;color:#4A6B7A;line-height:1.85;margin:0 0 20px 0;">
          I'm Shohei Toguchi — based in Okinawa, Japan. With a TOEIC score of 955 and deep fluency in Japanese, Uchinaaguchi, and Mandarin Chinese, I bridge cultures through cinematic storytelling.
        </p>
        <p style="font-family:'Inter',sans-serif;font-size:16px;color:#4A6B7A;line-height:1.85;margin:0 0 36px 0;">
          My work focuses on revealing the untold histories of the Ryukyu Kingdom — bringing Okinawa's indigenous identity, language, and resilience to global audiences across YouTube, social media, and beyond.
        </p>
        <a href="/en/about/" style="text-decoration:none;color:#7EC8E3;font-family:'DM Sans',sans-serif;font-weight:700;font-size:13px;letter-spacing:0.08em;text-transform:uppercase;border-bottom:2px solid #7EC8E3;padding-bottom:4px;">Read Full Bio →</a>
      </div>
      <div>
        <!-- Stats grid -->
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;">
          <div style="background:#F5FAFB;border:1px solid #BFE8F7;border-radius:8px;padding:32px 24px;">
            <p style="font-family:'DM Sans',sans-serif;font-size:40px;font-weight:900;color:#7EC8E3;margin:0 0 8px 0;line-height:1;">2,400+</p>
            <p style="font-family:'Inter',sans-serif;font-size:13px;color:#4A6B7A;margin:0;line-height:1.5;">YouTube Subscribers<br/><span style="color:#A0B8C4;font-size:11px;">@letsgokinawa</span></p>
          </div>
          <div style="background:#F5FAFB;border:1px solid #BFE8F7;border-radius:8px;padding:32px 24px;">
            <p style="font-family:'DM Sans',sans-serif;font-size:40px;font-weight:900;color:#7EC8E3;margin:0 0 8px 0;line-height:1;">955</p>
            <p style="font-family:'Inter',sans-serif;font-size:13px;color:#4A6B7A;margin:0;line-height:1.5;">TOEIC Score<br/><span style="color:#A0B8C4;font-size:11px;">Professional English</span></p>
          </div>
          <div style="background:#1A3A4A;border:1px solid rgba(126,200,227,0.2);border-radius:8px;padding:32px 24px;">
            <p style="font-family:'DM Sans',sans-serif;font-size:40px;font-weight:900;color:#7EC8E3;margin:0 0 8px 0;line-height:1;">3</p>
            <p style="font-family:'Inter',sans-serif;font-size:13px;color:rgba(245,250,251,0.6);margin:0;line-height:1.5;">Language Markets<br/><span style="color:rgba(245,250,251,0.35);font-size:11px;">EN · JA · ZH</span></p>
          </div>
          <div style="background:#1A3A4A;border:1px solid rgba(126,200,227,0.2);border-radius:8px;padding:32px 24px;">
            <p style="font-family:'DM Sans',sans-serif;font-size:40px;font-weight:900;color:#7EC8E3;margin:0 0 8px 0;line-height:1;">15+</p>
            <p style="font-family:'Inter',sans-serif;font-size:13px;color:rgba(245,250,251,0.6);margin:0;line-height:1.5;">Documentary Films<br/><span style="color:rgba(245,250,251,0.35);font-size:11px;">Long-form productions</span></p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── FEATURED WORK ── -->
  <section style="padding:120px 40px;background:#F5FAFB;border-top:1px solid #BFE8F7;border-bottom:1px solid #BFE8F7;">
    <div style="max-width:1200px;margin:0 auto;">
      <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:24px;margin-bottom:64px;">
        <div style="display:flex;align-items:center;gap:20px;">
          <div style="width:5px;height:36px;background:#7EC8E3;border-radius:2px;"></div>
          <div>
            <p style="font-family:'DM Sans',sans-serif;font-size:11px;font-weight:700;letter-spacing:0.3em;text-transform:uppercase;color:#7EC8E3;margin:0 0 8px 0;">Selected Work</p>
            <h2 style="font-family:'DM Sans',sans-serif;font-size:clamp(28px,4vw,40px);font-weight:800;color:#1A3A4A;margin:0;letter-spacing:-0.02em;">Featured Documentaries</h2>
          </div>
        </div>
        <a href="/en/portfolio/" style="text-decoration:none;color:#7EC8E3;font-family:'DM Sans',sans-serif;font-weight:700;font-size:12px;letter-spacing:0.1em;text-transform:uppercase;border-bottom:1px solid #7EC8E3;padding-bottom:3px;">View All Work →</a>
      </div>

      <!-- Video grid: Norikura-style cards -->
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:32px;">

        <!-- Card 1 -->
        <article style="background:#FFFFFF;border:1px solid #BFE8F7;border-radius:8px;overflow:hidden;transition:box-shadow 0.3s;">
          <div style="position:relative;padding-bottom:56.25%;height:0;background:#0E2330;">
            <iframe style="position:absolute;top:0;left:0;width:100%;height:100%;border:0;" src="https://www.youtube.com/embed/2v2vOrz5RXA" title="Battle of Okinawa" allow="accelerometer;autoplay;clipboard-write;encrypted-media;gyroscope;picture-in-picture" allowfullscreen loading="lazy"></iframe>
          </div>
          <div style="padding:28px;">
            <span style="display:inline-block;background:#E8F6FB;color:#5BAAC8;font-family:'DM Sans',sans-serif;font-size:10px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;padding:5px 12px;border-radius:2px;margin-bottom:14px;">Documentary</span>
            <h3 style="font-family:'DM Sans',sans-serif;font-size:18px;font-weight:700;color:#1A3A4A;margin:0 0 10px 0;line-height:1.3;">10 Realities of the Battle of Okinawa</h3>
            <p style="font-family:'Inter',sans-serif;font-size:13px;color:#4A6B7A;line-height:1.7;margin:0 0 20px 0;">A peaceful kingdom crushed between empires. Exploring WWII Okinawa and its lasting impact.</p>
            <a href="/blog/battle-of-okinawa/" style="text-decoration:none;color:#7EC8E3;font-family:'DM Sans',sans-serif;font-weight:700;font-size:12px;letter-spacing:0.06em;text-transform:uppercase;">Read Article →</a>
          </div>
        </article>

        <!-- Card 2 -->
        <article style="background:#FFFFFF;border:1px solid #BFE8F7;border-radius:8px;overflow:hidden;">
          <div style="position:relative;padding-bottom:56.25%;height:0;background:#0E2330;">
            <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#1A3A4A,#0E2330);">
              <span style="color:rgba(126,200,227,0.3);font-family:'DM Sans',sans-serif;font-size:12px;letter-spacing:0.15em;">COMING SOON</span>
            </div>
          </div>
          <div style="padding:28px;">
            <span style="display:inline-block;background:#E8F6FB;color:#5BAAC8;font-family:'DM Sans',sans-serif;font-size:10px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;padding:5px 12px;border-radius:2px;margin-bottom:14px;">Culture</span>
            <h3 style="font-family:'DM Sans',sans-serif;font-size:18px;font-weight:700;color:#1A3A4A;margin:0 0 10px 0;line-height:1.3;">The Legend of Sanshin: Okinawa's Soul Instrument</h3>
            <p style="font-family:'Inter',sans-serif;font-size:13px;color:#4A6B7A;line-height:1.7;margin:0 0 20px 0;">How a three-stringed lute became the beating heart of Ryukyuan identity and resistance.</p>
            <a href="/blog/sanshin-legend/" style="text-decoration:none;color:#7EC8E3;font-family:'DM Sans',sans-serif;font-weight:700;font-size:12px;letter-spacing:0.06em;text-transform:uppercase;">Read Article →</a>
          </div>
        </article>

        <!-- Card 3 -->
        <article style="background:#FFFFFF;border:1px solid #BFE8F7;border-radius:8px;overflow:hidden;">
          <div style="position:relative;padding-bottom:56.25%;height:0;background:#0E2330;">
            <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#1A3A4A,#0E2330);">
              <span style="color:rgba(126,200,227,0.3);font-family:'DM Sans',sans-serif;font-size:12px;letter-spacing:0.15em;">COMING SOON</span>
            </div>
          </div>
          <div style="padding:28px;">
            <span style="display:inline-block;background:#E8F6FB;color:#5BAAC8;font-family:'DM Sans',sans-serif;font-size:10px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;padding:5px 12px;border-radius:2px;margin-bottom:14px;">History</span>
            <h3 style="font-family:'DM Sans',sans-serif;font-size:18px;font-weight:700;color:#1A3A4A;margin:0 0 10px 0;line-height:1.3;">Uchinaanchu in Hawaii: Diaspora &amp; Identity</h3>
            <p style="font-family:'Inter',sans-serif;font-size:13px;color:#4A6B7A;line-height:1.7;margin:0 0 20px 0;">Tracing the journey of Okinawan immigrants who built new lives across the Pacific.</p>
            <a href="/blog/uchinaanchu-in-hawaii/" style="text-decoration:none;color:#7EC8E3;font-family:'DM Sans',sans-serif;font-weight:700;font-size:12px;letter-spacing:0.06em;text-transform:uppercase;">Read Article →</a>
          </div>
        </article>

      </div>
    </div>
  </section>

  <!-- ── SERVICES ── -->
  <section style="padding:120px 40px;background:#1A3A4A;position:relative;overflow:hidden;">
    <!-- Watermark -->
    <div style="position:absolute;right:-40px;top:50%;transform:translateY(-50%);font-family:'DM Sans',sans-serif;font-size:280px;font-weight:900;color:rgba(126,200,227,0.04);line-height:1;user-select:none;pointer-events:none;letter-spacing:-0.05em;">琉</div>

    <div style="max-width:1200px;margin:0 auto;position:relative;z-index:1;">
      <div style="display:flex;align-items:center;gap:20px;margin-bottom:64px;">
        <div style="width:5px;height:36px;background:#7EC8E3;border-radius:2px;"></div>
        <div>
          <p style="font-family:'DM Sans',sans-serif;font-size:11px;font-weight:700;letter-spacing:0.3em;text-transform:uppercase;color:#7EC8E3;margin:0 0 8px 0;">What I Do</p>
          <h2 style="font-family:'DM Sans',sans-serif;font-size:clamp(28px,4vw,40px);font-weight:800;color:#F5FAFB;margin:0;letter-spacing:-0.02em;">Video Production Services</h2>
        </div>
      </div>

      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:24px;">
        <div style="background:rgba(126,200,227,0.07);border:1px solid rgba(126,200,227,0.18);border-radius:8px;padding:40px 32px;">
          <p style="font-family:'DM Sans',sans-serif;font-size:11px;font-weight:800;letter-spacing:0.2em;color:#7EC8E3;margin:0 0 20px 0;">01</p>
          <h3 style="font-family:'DM Sans',sans-serif;font-size:20px;font-weight:700;color:#F5FAFB;margin:0 0 14px 0;">Documentary Films</h3>
          <p style="font-family:'Inter',sans-serif;font-size:14px;color:rgba(245,250,251,0.6);line-height:1.8;margin:0;">Long-form cultural storytelling (15–30 min). Deep research, multilingual scripting, cinematic editing.</p>
        </div>
        <div style="background:rgba(126,200,227,0.12);border:1px solid rgba(126,200,227,0.35);border-radius:8px;padding:40px 32px;">
          <p style="font-family:'DM Sans',sans-serif;font-size:11px;font-weight:800;letter-spacing:0.2em;color:#7EC8E3;margin:0 0 20px 0;">02</p>
          <h3 style="font-family:'DM Sans',sans-serif;font-size:20px;font-weight:700;color:#F5FAFB;margin:0 0 14px 0;">Short-form &amp; Social</h3>
          <p style="font-family:'Inter',sans-serif;font-size:14px;color:rgba(245,250,251,0.6);line-height:1.8;margin:0;">YouTube Shorts, Reels, TikTok — viral-optimised cuts for English, Japanese &amp; Chinese audiences.</p>
        </div>
        <div style="background:rgba(126,200,227,0.07);border:1px solid rgba(126,200,227,0.18);border-radius:8px;padding:40px 32px;">
          <p style="font-family:'DM Sans',sans-serif;font-size:11px;font-weight:800;letter-spacing:0.2em;color:#7EC8E3;margin:0 0 20px 0;">03</p>
          <h3 style="font-family:'DM Sans',sans-serif;font-size:20px;font-weight:700;color:#F5FAFB;margin:0 0 14px 0;">Corporate &amp; Events</h3>
          <p style="font-family:'Inter',sans-serif;font-size:14px;color:rgba(245,250,251,0.6);line-height:1.8;margin:0;">Cinematic coverage for Okinawa-based businesses, events, and tourism with global distribution in mind.</p>
        </div>
      </div>

      <div style="margin-top:56px;display:flex;gap:20px;flex-wrap:wrap;align-items:center;">
        <a href="/en/services/" style="text-decoration:none;background:#7EC8E3;color:#1A3A4A;font-family:'DM Sans',sans-serif;font-weight:700;font-size:13px;letter-spacing:0.06em;text-transform:uppercase;padding:14px 32px;border-radius:4px;">View Services &amp; Pricing</a>
        <a href="/en/contact/" style="text-decoration:none;color:#7EC8E3;font-family:'DM Sans',sans-serif;font-weight:700;font-size:13px;letter-spacing:0.06em;text-transform:uppercase;border-bottom:1px solid #7EC8E3;padding-bottom:3px;">Get in Touch →</a>
      </div>
    </div>
  </section>

  <!-- ── LATEST ARTICLES ── -->
  <section style="padding:120px 40px;background:#FFFFFF;">
    <div style="max-width:1200px;margin:0 auto;">
      <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:24px;margin-bottom:64px;">
        <div style="display:flex;align-items:center;gap:20px;">
          <div style="width:5px;height:36px;background:#7EC8E3;border-radius:2px;"></div>
          <div>
            <p style="font-family:'DM Sans',sans-serif;font-size:11px;font-weight:700;letter-spacing:0.3em;text-transform:uppercase;color:#7EC8E3;margin:0 0 8px 0;">Learn</p>
            <h2 style="font-family:'DM Sans',sans-serif;font-size:clamp(28px,4vw,40px);font-weight:800;color:#1A3A4A;margin:0;letter-spacing:-0.02em;">Okinawa Stories</h2>
          </div>
        </div>
        <a href="/blog/" style="text-decoration:none;color:#7EC8E3;font-family:'DM Sans',sans-serif;font-weight:700;font-size:12px;letter-spacing:0.1em;text-transform:uppercase;border-bottom:1px solid #7EC8E3;padding-bottom:3px;">All Articles →</a>
      </div>

      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:28px;">
        {[
          { href: '/blog/battle-of-okinawa/', tag: 'History', title: 'Battle of Okinawa: 10 Realities', desc: 'The war that shaped modern Okinawa — facts that history textbooks ignore.' },
          { href: '/blog/sanshin-legend/', tag: 'Culture', title: 'The Legend of the Sanshin', desc: 'How a three-stringed lute became the symbol of Ryukyuan identity.' },
          { href: '/blog/sanshin-vs-shamisen/', tag: 'Culture', title: 'Sanshin vs. Shamisen', desc: 'Two instruments, two cultures — the stories hidden in the strings.' },
          { href: '/blog/uchinaanchu-in-hawaii/', tag: 'Diaspora', title: 'Uchinaanchu in Hawaii', desc: 'The Okinawan diaspora that built bridges across the Pacific.' },
        ].map(({ href, tag, title, desc }) => (
          <a href={href} style="text-decoration:none;display:block;background:#F5FAFB;border:1px solid #BFE8F7;border-radius:8px;padding:28px;transition:border-color 0.2s,transform 0.2s;">
            <span style="display:inline-block;background:#E8F6FB;color:#5BAAC8;font-family:'DM Sans',sans-serif;font-size:10px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;padding:4px 10px;border-radius:2px;margin-bottom:14px;">{tag}</span>
            <h3 style="font-family:'DM Sans',sans-serif;font-size:16px;font-weight:700;color:#1A3A4A;margin:0 0 10px 0;line-height:1.35;">{title}</h3>
            <p style="font-family:'Inter',sans-serif;font-size:13px;color:#4A6B7A;line-height:1.7;margin:0;">{desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ── CTA BAND ── -->
  <section style="padding:80px 40px;background:linear-gradient(105deg,#1A3A4A 0%,#2B5873 100%);border-top:3px solid #7EC8E3;">
    <div style="max-width:900px;margin:0 auto;text-align:center;">
      <h2 style="font-family:'DM Sans',sans-serif;font-size:clamp(28px,5vw,48px);font-weight:800;color:#F5FAFB;margin:0 0 20px 0;letter-spacing:-0.02em;">Need a video editor for your project?</h2>
      <p style="font-family:'Inter',sans-serif;font-size:16px;color:rgba(245,250,251,0.65);margin:0 0 48px 0;line-height:1.7;">Documentary films, social content, corporate videos — I bring Okinawa's cinematic perspective to every frame.</p>
      <a href="/en/contact/" style="text-decoration:none;display:inline-block;background:#7EC8E3;color:#1A3A4A;font-family:'DM Sans',sans-serif;font-weight:700;font-size:14px;letter-spacing:0.06em;text-transform:uppercase;padding:18px 48px;border-radius:4px;">Let's Work Together →</a>
    </div>
  </section>

</LayoutEN>
