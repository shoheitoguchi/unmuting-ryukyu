---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Blog | Unmuting Ryukyu">

	<!-- PAGE HEADER -->
	<section style="padding:72px 32px 56px;background:#1C2C4F;position:relative;overflow:hidden;border-bottom:4px solid #8B1D25;">
		<div style="position:absolute;top:0;left:0;width:5px;height:100%;background:#8B1D25;"></div>
		<div style="max-width:1100px;margin:0 auto;position:relative;z-index:1;">
			<p style="color:#8B1D25;font-family:'Noto Sans JP',sans-serif;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.3em;margin:0 0 16px 0;">Stories & Insights</p>
			<h1 style="font-family:'Shippori Mincho','Noto Serif JP',serif;font-size:clamp(36px,6vw,64px);font-weight:700;color:#F0EBE3;margin:0 0 16px 0;line-height:1.05;">Blog</h1>
			<p style="color:#A8B8C8;font-family:'Noto Serif JP',serif;font-size:16px;margin:0;">Deep dives into the stories behind our documentaries.</p>
		</div>
	</section>

	<!-- BLOG LIST -->
	<section style="padding:80px 32px 96px;background:#F0EBE3;">
		<div style="max-width:840px;margin:0 auto;">

			<!-- Post 1 — 3 Reasons (Newest) -->
			<a href="/blog/three-reasons-okinawa/" style="text-decoration:none;display:block;background:#fff;border:1px solid #D0C5BA;border-left:4px solid #8B1D25;padding:36px 40px;margin-bottom:3px;box-shadow:2px 2px 0px #D0C5BA;">
				<div style="display:flex;align-items:center;gap:12px;margin-bottom:14px;">
					<span style="display:inline-block;background:#8B1D25;color:#F0EBE3;font-family:'Noto Sans JP',sans-serif;font-size:10px;font-weight:700;padding:4px 12px;letter-spacing:0.1em;text-transform:uppercase;">Documentary</span>
					<span style="color:#8B8078;font-family:'Noto Sans JP',sans-serif;font-size:12px;">February 2026</span>
				</div>
				<h2 style="font-family:'Shippori Mincho','Noto Serif JP',serif;font-size:clamp(18px,3vw,24px);font-weight:700;color:#1C2C4F;margin:0 0 12px 0;line-height:1.35;">3 Reasons why the southernmost part of Japan is not Japan</h2>
				<p style="color:#4A3F3B;font-family:'Noto Serif JP',serif;font-size:15px;line-height:1.9;margin:0 0 20px 0;">Are Okinawans simply Japanese, or something else entirely? For 450 years, Okinawa was an independent kingdom with its own unique culture, language, and governance...</p>
				<span style="color:#8B1D25;font-family:'Noto Sans JP',sans-serif;font-weight:700;font-size:12px;letter-spacing:0.08em;text-transform:uppercase;">Read More →</span>
			</a>

			<!-- Post 2 — Battle of Okinawa -->
			<a href="/blog/battle-of-okinawa/" style="text-decoration:none;display:block;background:#fff;border:1px solid #D0C5BA;border-left:4px solid #1C2C4F;padding:36px 40px;margin-bottom:3px;margin-top:24px;box-shadow:2px 2px 0px #D0C5BA;">
				<div style="display:flex;align-items:center;gap:12px;margin-bottom:14px;">
					<span style="display:inline-block;background:#8B1D25;color:#F0EBE3;font-family:'Noto Sans JP',sans-serif;font-size:10px;font-weight:700;padding:4px 12px;letter-spacing:0.1em;text-transform:uppercase;">Documentary</span>
					<span style="color:#8B8078;font-family:'Noto Sans JP',sans-serif;font-size:12px;">March 2026</span>
				</div>
				<h2 style="font-family:'Shippori Mincho','Noto Serif JP',serif;font-size:clamp(18px,3vw,24px);font-weight:700;color:#1C2C4F;margin:0 0 12px 0;line-height:1.35;">Battle of Okinawa: 10 Realities You Never Know</h2>
				<p style="color:#4A3F3B;font-family:'Noto Serif JP',serif;font-size:15px;line-height:1.9;margin:0 0 20px 0;">The Battle of Okinawa was one of the bloodiest battles of the Pacific War. But what most people don't know is how deeply it still shapes the island today...</p>
				<span style="color:#8B1D25;font-family:'Noto Sans JP',sans-serif;font-weight:700;font-size:12px;letter-spacing:0.08em;text-transform:uppercase;">Read More →</span>
			</a>

			<!-- Post 3 — Sanshin Legend -->
			<a href="/blog/sanshin-legend/" style="text-decoration:none;display:block;background:#fff;border:1px solid #D0C5BA;border-left:4px solid #8B1D25;padding:36px 40px;margin-bottom:3px;margin-top:24px;box-shadow:2px 2px 0px #D0C5BA;">
				<div style="display:flex;align-items:center;gap:12px;margin-bottom:14px;">
					<span style="display:inline-block;background:#8B1D25;color:#F0EBE3;font-family:'Noto Sans JP',sans-serif;font-size:10px;font-weight:700;padding:4px 12px;letter-spacing:0.1em;text-transform:uppercase;">Ryukyuan Legend</span>
					<span style="color:#8B8078;font-family:'Noto Sans JP',sans-serif;font-size:12px;">February 2025</span>
				</div>
				<h2 style="font-family:'Shippori Mincho','Noto Serif JP',serif;font-size:clamp(18px,3vw,24px);font-weight:700;color:#1C2C4F;margin:0 0 12px 0;line-height:1.35;">"If you played the Sanshin... you were called a loser."</h2>
				<p style="color:#4A3F3B;font-family:'Noto Serif JP',serif;font-size:15px;line-height:1.9;margin:0 0 20px 0;">Did you know that playing the Sanshin — the iconic instrument of Okinawa — once carried a deep social stigma? This documentary uncovers the fascinating history behind this...</p>
				<span style="color:#8B1D25;font-family:'Noto Sans JP',sans-serif;font-weight:700;font-size:12px;letter-spacing:0.08em;text-transform:uppercase;">Read More →</span>
			</a>

			<!-- Post 4 — Uchinaanchu in Hawai'i -->
			<a href="/blog/uchinaanchu-in-hawaii/" style="text-decoration:none;display:block;background:#fff;border:1px solid #D0C5BA;border-left:4px solid #1C2C4F;padding:36px 40px;margin-bottom:3px;margin-top:24px;box-shadow:2px 2px 0px #D0C5BA;">
				<div style="display:flex;align-items:center;gap:12px;margin-bottom:14px;">
					<span style="display:inline-block;background:#8B1D25;color:#F0EBE3;font-family:'Noto Sans JP',sans-serif;font-size:10px;font-weight:700;padding:4px 12px;letter-spacing:0.1em;text-transform:uppercase;">Documentary</span>
					<span style="color:#8B8078;font-family:'Noto Sans JP',sans-serif;font-size:12px;">June 2025</span>
				</div>
				<h2 style="font-family:'Shippori Mincho','Noto Serif JP',serif;font-size:clamp(18px,3vw,24px);font-weight:700;color:#1C2C4F;margin:0 0 12px 0;line-height:1.35;">Uchinaanchu in Hawai'i: How do they see Okinawa???</h2>
				<p style="color:#4A3F3B;font-family:'Noto Serif JP',serif;font-size:15px;line-height:1.9;margin:0 0 20px 0;">Dylan, from Hawai'i and of Okinawan descent, travels to Okinawa as a Kempi student. This documentary follows their journey reconnecting with their ancestral homeland...</p>
				<span style="color:#8B1D25;font-family:'Noto Sans JP',sans-serif;font-weight:700;font-size:12px;letter-spacing:0.08em;text-transform:uppercase;">Read More →</span>
			</a>

			<!-- Subscribe CTA -->
			<div style="background:#E8E2D8;border:1px solid #D0C5BA;border-left:4px solid #1C2C4F;padding:48px 40px;text-align:center;margin-top:40px;">
				<p style="color:#1C2C4F;font-family:'Noto Sans JP',sans-serif;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.3em;margin:0 0 16px 0;">More Stories Coming</p>
				<p style="color:#4A3F3B;font-family:'Noto Serif JP',serif;font-size:15px;line-height:1.9;margin:0 0 28px 0;max-width:480px;margin-left:auto;margin-right:auto;">Each new documentary comes with a full article. Subscribe to be notified.</p>
				<a href="https://www.youtube.com/@letsgokinawa?sub_confirmation=1" target="_blank" rel="noopener noreferrer" style="text-decoration:none;display:inline-flex;align-items:center;gap:8px;background:#8B1D25;color:#F0EBE3;font-family:'Noto Sans JP',sans-serif;font-weight:700;padding:12px 28px;border-radius:2px;font-size:13px;letter-spacing:0.05em;">
					Subscribe on YouTube →
				</a>
			</div>

		</div>
	</section>

</Layout>
