---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Blog | Unmuting Ryukyu">

	<!-- PAGE HEADER -->
	<section style="padding:100px 32px 80px;background:#1C2C4F;position:relative;overflow:hidden;border-bottom:1px solid rgba(255,255,255,0.12);">
		<div style="position:absolute;top:0;left:0;width:6px;height:100%;background:#8B1D25;"></div>
		<div style="max-width:1100px;margin:0 auto;position:relative;z-index:1;">
			<p style="color:#8B1D25;font-family:'DM Sans', sans-serif;font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:0.3em;margin:0 0 20px 0;">Stories & Insights</p>
			<h1 style="font-family:'DM Sans', sans-serif;font-size:clamp(40px,8vw,72px);font-weight:800;color:#F0EBE3;margin:0 0 24px 0;line-height:1;letter-spacing:-0.03em;">The Journal</h1>
			<p style="color:#A8B8C8;font-family:'Inter', sans-serif;font-size:18px;margin:0;max-width:600px;line-height:1.6;">Deep dives into the stories, history, and people behind our documentaries.</p>
		</div>
	</section>

	<!-- BLOG LIST -->
	<section style="padding:100px 32px 120px;background:#F0EBE3;">
		<div style="max-width:900px;margin:0 auto;">

			<!-- Featured Post: Henoko (Newest) -->
			<a href="/blog/henoko/" style="text-decoration:none;display:block;background:#fff;border:1px solid #D0C5BA;border-left:4px solid #8B1D25;margin-bottom:48px;border-radius:4px;overflow:hidden;transition:transform 0.2s, box-shadow 0.2s;">
				<div style="position:relative;width:100%;padding-bottom:45%;overflow:hidden;background:#1C2C4F;">
					<div style="position:absolute;inset:0;background:linear-gradient(45deg, #0d1a30 0%, #1C2C4F 100%);display:flex;align-items:center;justify-content:center;">
                        <span style="font-family:'DM Sans', sans-serif;font-size:40px;font-weight:900;color:rgba(200,168,106,0.15);letter-spacing:0.2em;text-transform:uppercase;">Henoko</span>
                    </div>
					<div style="position:absolute;inset:0;background:linear-gradient(to top, rgba(28,44,79,0.8) 0%, transparent 80%);"></div>
				</div>
				<div style="padding:40px;">
					<div style="display:flex;align-items:center;gap:16px;margin-bottom:20px;">
						<span style="display:inline-block;background:#8B1D25;color:#F0EBE3;font-family:'DM Sans', sans-serif;font-size:10px;font-weight:700;padding:5px 14px;border-radius:2px;letter-spacing:0.1em;text-transform:uppercase;">New Documentary</span>
						<span style="color:#4A3F3B;font-family:'Inter', sans-serif;font-size:13px;">March 9, 2026</span>
					</div>
					<h2 style="font-family:'DM Sans', sans-serif;font-size:clamp(24px,4vw,32px);font-weight:800;color:#1C2C4F;margin:0 0 16px 0;line-height:1.2;letter-spacing:-0.01em;">Does Democracy Apply to Okinawa? The Henoko Base Issue</h2>
					<p style="color:#4A3F3B;font-family:'Inter', sans-serif;font-size:16px;line-height:1.8;margin:0 0 24px 0;">When the local will of 72% is ignored by the national government, it brings into question the very principles of democracy in Ryukyu.</p>
					<span style="color:#C8A86A;font-family:'DM Sans', sans-serif;font-weight:700;font-size:13px;letter-spacing:0.1em;text-transform:uppercase;border-bottom:1px solid #C8A86A;padding-bottom:2px;">Read the Full Script →</span>
				</div>
			</a>

			<!-- Normal Post Items -->
			<div style="display:grid;gap:24px;">

				<!-- Post: Battle of Okinawa -->
				<a href="/blog/battle-of-okinawa/" style="text-decoration:none;display:block;background:#fff;border:1px solid #D0C5BA;border-left:4px solid #C8A86A;padding:32px 40px;border-radius:4px;transition:box-shadow 0.2s;">
					<div style="display:flex;align-items:center;gap:16px;margin-bottom:16px;">
						<span style="color:#C8A86A;font-family:'DM Sans', sans-serif;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;">History</span>
						<span style="color:#4A3F3B;font-family:'Inter', sans-serif;font-size:12px;">March 2026</span>
					</div>
					<h3 style="font-family:'DM Sans', sans-serif;font-size:22px;font-weight:700;color:#1C2C4F;margin:0 0 12px 0;">10 Realities of the Battle of Okinawa You Never Knew</h3>
					<p style="color:#4A3F3B;font-family:'Inter', sans-serif;font-size:15px;line-height:1.8;margin:0 0 20px 0;">The "Typhoon of Steel" was more than a battle—it was the physical and spiritual erasure of Ryukyu.</p>
					<span style="color:#8B1D25;font-family:'DM Sans', sans-serif;font-weight:700;font-size:12px;letter-spacing:0.05em;text-transform:uppercase;">Read Entry →</span>
				</a>

				<!-- Post: Sanshin Day -->
				<a href="/blog/sanshin-day/" style="text-decoration:none;display:block;background:#fff;border:1px solid #D0C5BA;border-left:4px solid #C8A86A;padding:32px 40px;border-radius:4px;transition:box-shadow 0.2s;">
					<div style="display:flex;align-items:center;gap:16px;margin-bottom:16px;">
						<span style="color:#C8A86A;font-family:'DM Sans', sans-serif;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;">Culture</span>
						<span style="color:#4A3F3B;font-family:'Inter', sans-serif;font-size:12px;">March 4, 2026</span>
					</div>
					<h3 style="font-family:'DM Sans', sans-serif;font-size:22px;font-weight:700;color:#1C2C4F;margin:0 0 12px 0;">Sanshin Day: Why Okinawa Stops Everything on March 4th</h3>
					<p style="color:#4A3F3B;font-family:'Inter', sans-serif;font-size:15px;line-height:1.8;margin:0 0 20px 0;">Every year at 3:04 PM, thousands of Okinawans unite through the sound of the three-stringed instrument—a living act of cultural resilience.</p>
					<span style="color:#8B1D25;font-family:'DM Sans', sans-serif;font-weight:700;font-size:12px;letter-spacing:0.05em;text-transform:uppercase;">Read Entry →</span>
				</a>

                <!-- Post: 3 Reasons -->
				<a href="/blog/three-reasons-okinawa/" style="text-decoration:none;display:block;background:#fff;border:1px solid #D0C5BA;border-left:4px solid #C8A86A;padding:32px 40px;border-radius:4px;transition:box-shadow 0.2s;">
					<div style="display:flex;align-items:center;gap:16px;margin-bottom:16px;">
						<span style="color:#C8A86A;font-family:'DM Sans', sans-serif;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;">Identity</span>
						<span style="color:#4A3F3B;font-family:'Inter', sans-serif;font-size:12px;">February 2026</span>
					</div>
					<h3 style="font-family:'DM Sans', sans-serif;font-size:22px;font-weight:700;color:#1C2C4F;margin:0 0 12px 0;">3 Reasons why the southernmost part of Japan is not Japan</h3>
					<p style="color:#4A3F3B;font-family:'Inter', sans-serif;font-size:15px;line-height:1.8;margin:0 0 20px 0;">Are Okinawans simply Japanese? For 450 years, Ryukyu was an independent kingdom with its own language and soul.</p>
					<span style="color:#8B1D25;font-family:'DM Sans', sans-serif;font-weight:700;font-size:12px;letter-spacing:0.05em;text-transform:uppercase;">Read Entry →</span>
				</a>

				<!-- Post: Hawaiian Uchinaanchu -->
				<a href="/blog/uchinaanchu-in-hawaii/" style="text-decoration:none;display:block;background:#fff;border:1px solid #D0C5BA;border-left:4px solid #C8A86A;padding:32px 40px;border-radius:4px;transition:box-shadow 0.2s;">
					<div style="display:flex;align-items:center;gap:16px;margin-bottom:16px;">
						<span style="color:#C8A86A;font-family:'DM Sans', sans-serif;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;">Diaspora</span>
						<span style="color:#4A3F3B;font-family:'Inter', sans-serif;font-size:12px;">June 2025</span>
					</div>
					<h3 style="font-family:'DM Sans', sans-serif;font-size:22px;font-weight:700;color:#1C2C4F;margin:0 0 12px 0;">Uchinaanchu in Hawai'i: Finding Home Across the Ocean</h3>
					<p style="color:#4A3F3B;font-family:'Inter', sans-serif;font-size:15px;line-height:1.8;margin:0 0 20px 0;">Dylan travels from Hawai'i to Okinawa to reconnect with his ancestral homeland. A journey of identity and shared heritage.</p>
					<span style="color:#8B1D25;font-family:'DM Sans', sans-serif;font-weight:700;font-size:12px;letter-spacing:0.05em;text-transform:uppercase;">Read Entry →</span>
				</a>

			</div>

			<!-- YouTube CTA -->
			<div style="border-top:1px solid #D0C5BA;padding-top:64px;margin-top:80px;text-align:center;">
				<p style="color:#4A3F3B;font-family:'Inter', sans-serif;font-size:16px;line-height:1.8;margin:0 0 24px 0;">Follow the documentary journey on YouTube.</p>
				<a href="https://www.youtube.com/@letsgokinawa" target="_blank" rel="noopener noreferrer" style="text-decoration:none;color:#C8A86A;font-family:'DM Sans', sans-serif;font-weight:700;font-size:14px;letter-spacing:0.1em;text-transform:uppercase;border-bottom:1px solid #C8A86A;padding-bottom:2px;">Watch on YouTube →</a>
			</div>

		</div>
	</section>

</Layout>
