---
import LayoutJA from '../../layouts/LayoutJA.astro';
---

<LayoutJA title="渡口翔平 | 動画編集者・ドキュメンタリー映像作家 — 沖縄・琉球">

  <!-- ── HERO ── -->
  <section style="position:relative;min-height:100vh;display:flex;align-items:center;overflow:hidden;">

    <div style="position:absolute;inset:0;z-index:0;">
      <div style="position:absolute;inset:0;background-image:url('/images/shuri-castle.jpg');background-size:cover;background-position:center;opacity:0;animation:heroSlide 18s 0s infinite;"></div>
      <div style="position:absolute;inset:0;background-image:url('/images/shuri-castle.jpg');background-size:cover;background-position:top;filter:hue-rotate(8deg) brightness(0.9);opacity:0;animation:heroSlide 18s 6s infinite;"></div>
      <div style="position:absolute;inset:0;background-image:url('/images/shuri-castle.jpg');background-size:cover;background-position:bottom;filter:saturate(1.1) brightness(0.85);opacity:0;animation:heroSlide 18s 12s infinite;"></div>
    </div>

    <div style="position:absolute;inset:0;z-index:1;background:linear-gradient(105deg,rgba(26,58,74,0.85) 0%,rgba(26,58,74,0.55) 55%,rgba(11,27,38,0.75) 100%);"></div>
    <div style="position:absolute;top:0;left:0;width:5px;height:100%;z-index:2;background:linear-gradient(to bottom,transparent,#7EC8E3 30%,#5BAAC8 70%,transparent);"></div>

    <div style="position:relative;z-index:3;max-width:1200px;margin:0 auto;padding:120px 40px 80px;width:100%;">
      <p style="font-family:'Noto Sans JP',sans-serif;font-size:11px;font-weight:700;letter-spacing:0.3em;color:#7EC8E3;margin:0 0 28px 0;">動画編集者 · ドキュメンタリー映像作家 · 文化発信者</p>

      <h1 style="font-family:'Noto Serif JP',serif;font-size:clamp(48px,8vw,100px);font-weight:700;line-height:0.95;letter-spacing:-0.01em;color:#F5FAFB;margin:0 0 12px 0;">
        渡口<br/>
        <span style="color:#7EC8E3;">翔平</span>
      </h1>

      <div style="width:56px;height:3px;background:#7EC8E3;margin:36px 0;"></div>

      <p style="font-family:'Noto Sans JP',sans-serif;font-size:clamp(15px,2vw,18px);color:rgba(245,250,251,0.75);line-height:2;max-width:500px;margin:0 0 56px 0;font-weight:300;">
        沖縄・琉球の歴史と文化を映像で世界へ。<br/>英語・日本語・中国語の3言語で発信する映像作家。
      </p>

      <div style="display:flex;gap:16px;flex-wrap:wrap;">
        <a href="/ja/portfolio/" style="text-decoration:none;display:inline-flex;align-items:center;gap:10px;background:#7EC8E3;color:#1A3A4A;font-family:'Noto Sans JP',sans-serif;font-weight:700;font-size:14px;letter-spacing:0.08em;padding:16px 36px;border-radius:4px;">
          ポートフォリオを見る →
        </a>
        <a href="https://www.youtube.com/@letsgokinawa" target="_blank" rel="noopener" style="text-decoration:none;display:inline-flex;align-items:center;gap:10px;border:1px solid rgba(126,200,227,0.4);color:#F5FAFB;font-family:'Noto Sans JP',sans-serif;font-weight:400;font-size:14px;padding:16px 36px;border-radius:4px;backdrop-filter:blur(4px);">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          YouTubeで見る
        </a>
      </div>
    </div>

    <div style="position:absolute;bottom:40px;left:50%;transform:translateX(-50%);z-index:3;display:flex;flex-direction:column;align-items:center;gap:8px;opacity:0.45;">
      <span style="font-family:'Noto Sans JP',sans-serif;font-size:10px;letter-spacing:0.2em;color:#7EC8E3;">スクロール</span>
      <div style="width:1px;height:40px;background:linear-gradient(to bottom,#7EC8E3,transparent);"></div>
    </div>
  </section>

  <style>
    @keyframes heroSlide {
      0%        { opacity:0; transform:scale(1.06); }
      5%        { opacity:1; transform:scale(1.03); }
      28%       { opacity:1; transform:scale(1.00); }
      36%,100%  { opacity:0; transform:scale(0.97); }
    }
  </style>

  <!-- ── SELF INTRO ── -->
  <section style="padding:120px 40px;background:#FFFFFF;">
    <div style="max-width:1100px;margin:0 auto;display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:80px;align-items:center;">
      <div>
        <p style="font-family:'Noto Sans JP',sans-serif;font-size:11px;font-weight:700;letter-spacing:0.3em;text-transform:uppercase;color:#7EC8E3;margin:0 0 20px 0;">自己紹介</p>
        <h2 style="font-family:'Noto Serif JP',serif;font-size:clamp(28px,4.5vw,44px);font-weight:700;color:#1A3A4A;margin:0 0 28px 0;line-height:1.2;">動画編集者として、<br/>沖縄を世界に伝える</h2>
        <div style="width:48px;height:3px;background:#7EC8E3;margin-bottom:28px;"></div>
        <p style="font-family:'Noto Sans JP',sans-serif;font-size:15px;color:#4A6B7A;line-height:2;margin:0 0 18px 0;font-weight:300;">
          沖縄在住の映像作家・渡口翔平です。TOEIC955点の英語力と、日本語・うちなーぐち・中国語の多言語能力を活かし、琉球の歴史と文化を世界3言語で発信しています。
        </p>
        <p style="font-family:'Noto Sans JP',sans-serif;font-size:15px;color:#4A6B7A;line-height:2;margin:0 0 32px 0;font-weight:300;">
          YouTubeチャンネル <strong style="color:#1A3A4A;">@letsgokinawa</strong> にて、英語圏・中華圏・日本向けのドキュメンタリーを制作。琉球王国の知られざる歴史、言語保存の課題、沖縄アイデンティティを映像で記録します。
        </p>
        <a href="/ja/about/" style="text-decoration:none;color:#7EC8E3;font-family:'Noto Sans JP',sans-serif;font-weight:700;font-size:13px;border-bottom:2px solid #7EC8E3;padding-bottom:4px;">詳しいプロフィールを見る →</a>
      </div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;">
        <div style="background:#F5FAFB;border:1px solid #BFE8F7;border-radius:8px;padding:28px 20px;">
          <p style="font-family:'DM Sans',sans-serif;font-size:36px;font-weight:900;color:#7EC8E3;margin:0 0 8px 0;line-height:1;">2,400+</p>
          <p style="font-family:'Noto Sans JP',sans-serif;font-size:12px;color:#4A6B7A;margin:0;line-height:1.6;">登録者数<br/><span style="color:#A0B8C4;font-size:11px;">@letsgokinawa</span></p>
        </div>
        <div style="background:#F5FAFB;border:1px solid #BFE8F7;border-radius:8px;padding:28px 20px;">
          <p style="font-family:'DM Sans',sans-serif;font-size:36px;font-weight:900;color:#7EC8E3;margin:0 0 8px 0;line-height:1;">TOEIC<br/>955</p>
          <p style="font-family:'Noto Sans JP',sans-serif;font-size:12px;color:#4A6B7A;margin:0;line-height:1.6;">英語力<br/><span style="color:#A0B8C4;font-size:11px;">ビジネスレベル</span></p>
        </div>
        <div style="background:#1A3A4A;border:1px solid rgba(126,200,227,0.2);border-radius:8px;padding:28px 20px;">
          <p style="font-family:'DM Sans',sans-serif;font-size:36px;font-weight:900;color:#7EC8E3;margin:0 0 8px 0;line-height:1;">3言語</p>
          <p style="font-family:'Noto Sans JP',sans-serif;font-size:12px;color:rgba(245,250,251,0.6);margin:0;line-height:1.6;">発信市場<br/><span style="color:rgba(245,250,251,0.35);font-size:11px;">英語・日本語・中国語</span></p>
        </div>
        <div style="background:#1A3A4A;border:1px solid rgba(126,200,227,0.2);border-radius:8px;padding:28px 20px;">
          <p style="font-family:'DM Sans',sans-serif;font-size:36px;font-weight:900;color:#7EC8E3;margin:0 0 8px 0;line-height:1;">15+</p>
          <p style="font-family:'Noto Sans JP',sans-serif;font-size:12px;color:rgba(245,250,251,0.6);margin:0;line-height:1.6;">ドキュメンタリー<br/><span style="color:rgba(245,250,251,0.35);font-size:11px;">長編制作本数</span></p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── FEATURED WORK ── -->
  <section style="padding:120px 40px;background:#F5FAFB;border-top:1px solid #BFE8F7;border-bottom:1px solid #BFE8F7;">
    <div style="max-width:1200px;margin:0 auto;">
      <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:24px;margin-bottom:64px;">
        <div style="display:flex;align-items:center;gap:20px;">
          <div style="width:5px;height:36px;background:#7EC8E3;border-radius:2px;"></div>
          <div>
            <p style="font-family:'Noto Sans JP',sans-serif;font-size:11px;font-weight:700;letter-spacing:0.25em;color:#7EC8E3;margin:0 0 8px 0;">代表作</p>
            <h2 style="font-family:'Noto Serif JP',serif;font-size:clamp(24px,4vw,36px);font-weight:700;color:#1A3A4A;margin:0;">制作した動画</h2>
          </div>
        </div>
        <a href="/ja/portfolio/" style="text-decoration:none;color:#7EC8E3;font-family:'Noto Sans JP',sans-serif;font-weight:700;font-size:12px;border-bottom:1px solid #7EC8E3;padding-bottom:3px;">すべての作品を見る →</a>
      </div>

      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:28px;">

        <article style="background:#FFFFFF;border:1px solid #BFE8F7;border-radius:8px;overflow:hidden;">
          <div style="position:relative;padding-bottom:56.25%;height:0;background:#0E2330;">
            <iframe style="position:absolute;top:0;left:0;width:100%;height:100%;border:0;" src="https://www.youtube.com/embed/2v2vOrz5RXA" title="沖縄戦" allow="accelerometer;autoplay;clipboard-write;encrypted-media;gyroscope;picture-in-picture" allowfullscreen loading="lazy"></iframe>
          </div>
          <div style="padding:24px;">
            <span style="display:inline-block;background:#E8F6FB;color:#5BAAC8;font-family:'Noto Sans JP',sans-serif;font-size:10px;font-weight:700;letter-spacing:0.1em;padding:4px 10px;border-radius:2px;margin-bottom:12px;">歴史</span>
            <h3 style="font-family:'Noto Serif JP',serif;font-size:17px;font-weight:700;color:#1A3A4A;margin:0 0 8px 0;line-height:1.4;">沖縄戦の10の真実</h3>
            <p style="font-family:'Noto Sans JP',sans-serif;font-size:13px;color:#4A6B7A;line-height:1.8;margin:0;font-weight:300;">帝国に挟まれた平和な王国の悲劇。沖縄戦と現代への影響を描く。</p>
          </div>
        </article>

        <article style="background:#FFFFFF;border:1px solid #BFE8F7;border-radius:8px;overflow:hidden;">
          <div style="position:relative;padding-bottom:56.25%;height:0;background:#0E2330;">
            <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#1A3A4A,#0E2330);">
              <span style="color:rgba(126,200,227,0.3);font-family:'Noto Sans JP',sans-serif;font-size:12px;letter-spacing:0.15em;">準備中</span>
            </div>
          </div>
          <div style="padding:24px;">
            <span style="display:inline-block;background:#E8F6FB;color:#5BAAC8;font-family:'Noto Sans JP',sans-serif;font-size:10px;font-weight:700;letter-spacing:0.1em;padding:4px 10px;border-radius:2px;margin-bottom:12px;">文化</span>
            <h3 style="font-family:'Noto Serif JP',serif;font-size:17px;font-weight:700;color:#1A3A4A;margin:0 0 8px 0;line-height:1.4;">三線伝説 — 琉球の魂</h3>
            <p style="font-family:'Noto Sans JP',sans-serif;font-size:13px;color:#4A6B7A;line-height:1.8;margin:0;font-weight:300;">三線がいかに琉球アイデンティティの象徴となったのか。その歴史と現在。</p>
          </div>
        </article>

        <article style="background:#FFFFFF;border:1px solid #BFE8F7;border-radius:8px;overflow:hidden;">
          <div style="position:relative;padding-bottom:56.25%;height:0;background:#0E2330;">
            <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#1A3A4A,#0E2330);">
              <span style="color:rgba(126,200,227,0.3);font-family:'Noto Sans JP',sans-serif;font-size:12px;letter-spacing:0.15em;">準備中</span>
            </div>
          </div>
          <div style="padding:24px;">
            <span style="display:inline-block;background:#E8F6FB;color:#5BAAC8;font-family:'Noto Sans JP',sans-serif;font-size:10px;font-weight:700;letter-spacing:0.1em;padding:4px 10px;border-radius:2px;margin-bottom:12px;">ディアスポラ</span>
            <h3 style="font-family:'Noto Serif JP',serif;font-size:17px;font-weight:700;color:#1A3A4A;margin:0 0 8px 0;line-height:1.4;">ハワイのウチナーンチュ</h3>
            <p style="font-family:'Noto Sans JP',sans-serif;font-size:13px;color:#4A6B7A;line-height:1.8;margin:0;font-weight:300;">太平洋を渡った沖縄移民の旅と、海外で守り続けるウチナーアイデンティティ。</p>
          </div>
        </article>

      </div>
    </div>
  </section>

  <!-- ── SERVICES ── -->
  <section style="padding:120px 40px;background:#1A3A4A;position:relative;overflow:hidden;">
    <div style="position:absolute;right:-40px;top:50%;transform:translateY(-50%);font-family:'Noto Serif JP',serif;font-size:280px;font-weight:700;color:rgba(126,200,227,0.04);line-height:1;user-select:none;pointer-events:none;">琉</div>

    <div style="max-width:1200px;margin:0 auto;position:relative;z-index:1;">
      <div style="display:flex;align-items:center;gap:20px;margin-bottom:64px;">
        <div style="width:5px;height:36px;background:#7EC8E3;border-radius:2px;"></div>
        <div>
          <p style="font-family:'Noto Sans JP',sans-serif;font-size:11px;font-weight:700;letter-spacing:0.25em;color:#7EC8E3;margin:0 0 8px 0;">サービス</p>
          <h2 style="font-family:'Noto Serif JP',serif;font-size:clamp(24px,4vw,36px);font-weight:700;color:#F5FAFB;margin:0;">動画制作サービス</h2>
        </div>
      </div>

      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:20px;">
        <div style="background:rgba(126,200,227,0.07);border:1px solid rgba(126,200,227,0.18);border-radius:8px;padding:36px 28px;">
          <p style="font-family:'DM Sans',sans-serif;font-size:11px;font-weight:800;letter-spacing:0.2em;color:#7EC8E3;margin:0 0 16px 0;">01</p>
          <h3 style="font-family:'Noto Serif JP',serif;font-size:18px;font-weight:700;color:#F5FAFB;margin:0 0 12px 0;">ドキュメンタリー制作</h3>
          <p style="font-family:'Noto Sans JP',sans-serif;font-size:13px;color:rgba(245,250,251,0.6);line-height:2;margin:0;font-weight:300;">15〜30分の長編文化ドキュメンタリー。多言語スクリプト対応。英語・日本語・中国語での編集・字幕制作。</p>
        </div>
        <div style="background:rgba(126,200,227,0.12);border:1px solid rgba(126,200,227,0.35);border-radius:8px;padding:36px 28px;">
          <p style="font-family:'DM Sans',sans-serif;font-size:11px;font-weight:800;letter-spacing:0.2em;color:#7EC8E3;margin:0 0 16px 0;">02</p>
          <h3 style="font-family:'Noto Serif JP',serif;font-size:18px;font-weight:700;color:#F5FAFB;margin:0 0 12px 0;">ショート・SNSコンテンツ</h3>
          <p style="font-family:'Noto Sans JP',sans-serif;font-size:13px;color:rgba(245,250,251,0.6);line-height:2;margin:0;font-weight:300;">YouTubeショート・Reels・TikTok向け。3言語市場を意識したバイラル最適化編集。</p>
        </div>
        <div style="background:rgba(126,200,227,0.07);border:1px solid rgba(126,200,227,0.18);border-radius:8px;padding:36px 28px;">
          <p style="font-family:'DM Sans',sans-serif;font-size:11px;font-weight:800;letter-spacing:0.2em;color:#7EC8E3;margin:0 0 16px 0;">03</p>
          <h3 style="font-family:'Noto Serif JP',serif;font-size:18px;font-weight:700;color:#F5FAFB;margin:0 0 12px 0;">企業・イベント映像</h3>
          <p style="font-family:'Noto Sans JP',sans-serif;font-size:13px;color:rgba(245,250,251,0.6);line-height:2;margin:0;font-weight:300;">沖縄の企業・観光・イベント向けの映像制作。海外市場への配信を見据えたシネマティック映像。</p>
        </div>
      </div>

      <div style="margin-top:52px;display:flex;gap:20px;flex-wrap:wrap;align-items:center;">
        <a href="/ja/services/" style="text-decoration:none;background:#7EC8E3;color:#1A3A4A;font-family:'Noto Sans JP',sans-serif;font-weight:700;font-size:13px;letter-spacing:0.05em;padding:14px 32px;border-radius:4px;">サービス詳細・料金を見る</a>
        <a href="/ja/contact/" style="text-decoration:none;color:#7EC8E3;font-family:'Noto Sans JP',sans-serif;font-weight:700;font-size:13px;border-bottom:1px solid #7EC8E3;padding-bottom:3px;">お問い合わせ →</a>
      </div>
    </div>
  </section>

  <!-- ── CTA ── -->
  <section style="padding:80px 40px;background:linear-gradient(105deg,#1A3A4A 0%,#2B5873 100%);border-top:3px solid #7EC8E3;">
    <div style="max-width:900px;margin:0 auto;text-align:center;">
      <h2 style="font-family:'Noto Serif JP',serif;font-size:clamp(24px,4vw,40px);font-weight:700;color:#F5FAFB;margin:0 0 16px 0;line-height:1.3;">映像制作のご依頼・ご相談</h2>
      <p style="font-family:'Noto Sans JP',sans-serif;font-size:15px;color:rgba(245,250,251,0.60);margin:0 0 44px 0;line-height:2;font-weight:300;">ドキュメンタリー・SNSコンテンツ・企業映像など、<br/>まずはお気軽にご連絡ください。</p>
      <a href="/ja/contact/" style="text-decoration:none;display:inline-block;background:#7EC8E3;color:#1A3A4A;font-family:'Noto Sans JP',sans-serif;font-weight:700;font-size:14px;letter-spacing:0.08em;padding:16px 44px;border-radius:4px;">お問い合わせはこちら →</a>
    </div>
  </section>

</LayoutJA>
