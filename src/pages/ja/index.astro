---
import LayoutJA from '../../layouts/LayoutJA.astro';
---

<LayoutJA title="渡口翔平 | 映像編集者・ドキュメンタリー作家 — 沖縄">

<style>
  /* ── Shared token aliases ── */
  :root {
    --bg-deep:    #09131F;
    --bg-base:    #0D1B2A;
    --bg-card:    #0F2030;
    --cyan:       #22D3EE;
    --cyan-dim:   #0891B2;
    --cyan-pale:  rgba(34,211,238,0.08);
    --cyan-border:rgba(34,211,238,0.16);
    --text-hi:    #EFF8FF;
    --text-mid:   #94C4D8;
    --text-lo:    #4A7A96;
  }

  /* ── Fade-up animation ── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(28px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .anim { opacity: 0; animation: fadeUp 0.9s forwards; }
  .anim-1 { animation-delay: 0.2s; }
  .anim-2 { animation-delay: 0.4s; }
  .anim-3 { animation-delay: 0.6s; }
  .anim-4 { animation-delay: 0.8s; }

  /* ── Section label ── */
  .label {
    font-family: 'DM Sans', sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--cyan);
    margin-bottom: 20px;
  }

  /* ── Section heading ── */
  .sec-h {
    font-family: 'Shippori Mincho', serif;
    font-weight: 600;
    color: var(--text-hi);
    line-height: 1.15;
    letter-spacing: 0.02em;
  }

  /* ── Divider line ── */
  .div-line {
    width: 40px;
    height: 2px;
    background: var(--cyan);
    margin: 28px 0;
  }

  /* ── Body copy ── */
  .body-copy {
    font-family: 'Noto Sans JP', sans-serif;
    font-weight: 300;
    color: var(--text-mid);
    line-height: 2.1;
  }

  /* ── Cyan button ── */
  .btn-cyan {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--cyan);
    color: var(--bg-deep);
    font-family: 'Noto Sans JP', sans-serif;
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 0.08em;
    padding: 16px 40px;
    border-radius: 3px;
    text-decoration: none;
    transition: opacity 0.2s, transform 0.2s;
  }
  .btn-cyan:hover { opacity: 0.88; transform: translateY(-2px); }

  /* ── Ghost button ── */
  .btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 1px solid var(--cyan-border);
    color: var(--text-mid);
    font-family: 'Noto Sans JP', sans-serif;
    font-weight: 400;
    font-size: 13px;
    letter-spacing: 0.06em;
    padding: 14px 32px;
    border-radius: 3px;
    text-decoration: none;
    transition: border-color 0.2s, color 0.2s;
  }
  .btn-ghost:hover { border-color: var(--cyan); color: var(--cyan); }
</style>


<!-- ══════════════════════════════════════════
     01  HERO
═══════════════════════════════════════════ -->
<section style="
  position: relative;
  min-height: 100svh;
  display: flex;
  align-items: center;
  overflow: hidden;
  background: var(--bg-deep);
">

  <!-- Background image -->
  <div style="
    position: absolute; inset: 0; z-index: 0;
    background-image: url('/images/shuri-castle.jpg');
    background-size: cover;
    background-position: center;
    opacity: 0.18;
  "></div>

  <!-- Gradient overlay -->
  <div style="
    position: absolute; inset: 0; z-index: 1;
    background: linear-gradient(
      110deg,
      rgba(9,19,31,0.97) 0%,
      rgba(9,19,31,0.70) 55%,
      rgba(9,19,31,0.92) 100%
    );
  "></div>

  <!-- Cyan left accent -->
  <div style="
    position: absolute; top: 0; left: 0;
    width: 3px; height: 100%;
    background: linear-gradient(to bottom, transparent, var(--cyan) 35%, var(--cyan-dim) 65%, transparent);
    z-index: 2;
  "></div>

  <!-- Grid lines (subtle) -->
  <div style="
    position: absolute; inset: 0; z-index: 2; pointer-events: none;
    background-image:
      linear-gradient(rgba(34,211,238,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(34,211,238,0.03) 1px, transparent 1px);
    background-size: 80px 80px;
  "></div>

  <!-- Content -->
  <div style="
    position: relative; z-index: 3;
    max-width: 1200px; margin: 0 auto;
    padding: 120px 40px 80px;
    width: 100%;
  ">

    <p class="label anim anim-1">映像編集者 · ドキュメンタリー作家 · 沖縄</p>

    <h1 class="anim anim-2" style="
      font-family: 'DM Sans', sans-serif;
      font-size: clamp(60px, 10vw, 120px);
      font-weight: 900;
      line-height: 0.88;
      letter-spacing: -0.04em;
      text-transform: uppercase;
      color: var(--text-hi);
      margin-bottom: 16px;
    ">
      SHOHEI<br>
      <span style="color: var(--cyan);">TOGUCHI</span>
    </h1>

    <p class="anim anim-3" style="
      font-family: 'Shippori Mincho', serif;
      font-size: clamp(16px, 2.2vw, 22px);
      font-weight: 400;
      color: var(--text-mid);
      letter-spacing: 0.12em;
      margin-top: 32px;
      margin-bottom: 56px;
    ">
      映像と言語で、失われゆく文化を記録する。
    </p>

    <div class="anim anim-4" style="display: flex; gap: 16px; flex-wrap: wrap;">
      <a href="/ja/portfolio/" class="btn-cyan">作品集を見る</a>
      <a href="/ja/contact/" class="btn-ghost">お問い合わせ</a>
    </div>

  </div>

  <!-- Scroll indicator -->
  <div style="
    position: absolute; bottom: 40px; left: 50%; transform: translateX(-50%);
    z-index: 3; display: flex; flex-direction: column; align-items: center; gap: 8px;
    opacity: 0.35;
  ">
    <span style="
      font-family: 'DM Sans', sans-serif;
      font-size: 9px; letter-spacing: 0.22em; text-transform: uppercase;
      color: var(--cyan);
    ">Scroll</span>
    <div style="width: 1px; height: 44px; background: linear-gradient(to bottom, var(--cyan), transparent);"></div>
  </div>
</section>


<!-- ══════════════════════════════════════════
     02  ABOUT
═══════════════════════════════════════════ -->
<section style="padding: 120px 40px; background: var(--bg-base);">
  <div style="max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 80px; align-items: center;">

    <!-- Text -->
    <div>
      <p class="label">About</p>
      <h2 class="sec-h" style="font-size: clamp(28px, 4vw, 44px);">
        記録することは、<br>敬意を示すことだ。
      </h2>
      <div class="div-line"></div>
      <p class="body-copy" style="font-size: 15px; margin-bottom: 20px;">
        沖縄在住の映像編集者・渡口翔平です。
        美しい風景、固有の言語、祖先から受け継がれた習慣——
        時間の流れの中で静かに消えゆくものを、映像とテクノロジーの力で次世代に残します。
      </p>
      <p class="body-copy" style="font-size: 15px; margin-bottom: 40px;">
        英語・日本語・中国語の3言語に対応し、
        国内外のクライアントの「伝えたいもの」を、
        文化的文脈を損なわずに正確に翻訳します。
      </p>
      <a href="/ja/about/" class="btn-ghost">プロフィール詳細 →</a>
    </div>

    <!-- Stats -->
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
      {[
        { num: '3言語', sub: 'EN · JA · ZH' },
        { num: 'TOEIC\n955', sub: '英語力' },
        { num: '15+', sub: '制作本数' },
        { num: '2,400+', sub: 'YouTube登録者' },
      ].map(({ num, sub }) => (
        <div style="
          background: var(--bg-card);
          border: 1px solid var(--cyan-border);
          border-radius: 6px;
          padding: 28px 20px;
        ">
          <p style="
            font-family: 'DM Sans', sans-serif;
            font-size: 28px; font-weight: 900;
            color: var(--cyan); line-height: 1.1;
            white-space: pre-line;
            margin-bottom: 8px;
          ">{num}</p>
          <p style="
            font-family: 'Noto Sans JP', sans-serif;
            font-size: 11px; color: var(--text-lo);
            letter-spacing: 0.06em;
          ">{sub}</p>
        </div>
      ))}
    </div>

  </div>
</section>


<!-- ══════════════════════════════════════════
     03  WORKS
═══════════════════════════════════════════ -->
<section style="padding: 120px 40px; background: var(--bg-deep); border-top: 1px solid var(--cyan-border);">
  <div style="max-width: 1200px; margin: 0 auto;">

    <div style="display: flex; align-items: flex-end; justify-content: space-between; flex-wrap: wrap; gap: 24px; margin-bottom: 64px;">
      <div>
        <p class="label">Works</p>
        <h2 class="sec-h" style="font-size: clamp(26px, 4vw, 40px);">制作実績</h2>
      </div>
      <a href="/ja/portfolio/" style="
        font-family: 'Noto Sans JP', sans-serif;
        font-size: 12px; color: var(--cyan);
        text-decoration: none;
        letter-spacing: 0.06em;
        border-bottom: 1px solid var(--cyan);
        padding-bottom: 2px;
      ">すべての作品を見る →</a>
    </div>

    <!-- Featured video -->
    <div style="
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 0;
      border: 1px solid var(--cyan-border);
      border-radius: 8px;
      overflow: hidden;
      margin-bottom: 40px;
    ">
      <div style="position: relative; padding-bottom: 56.25%; height: 0; background: var(--bg-deep);">
        <iframe
          style="position:absolute;top:0;left:0;width:100%;height:100%;border:0;"
          src="https://www.youtube.com/embed/2v2vOrz5RXA"
          title="沖縄戦ドキュメンタリー"
          allow="accelerometer;autoplay;clipboard-write;encrypted-media;gyroscope;picture-in-picture"
          allowfullscreen loading="lazy"
        ></iframe>
      </div>
      <div style="background: var(--bg-card); padding: 44px 40px; display: flex; flex-direction: column; justify-content: center;">
        <span style="
          display: inline-block;
          background: var(--cyan-pale);
          border: 1px solid var(--cyan-border);
          color: var(--cyan);
          font-family: 'DM Sans', sans-serif;
          font-size: 10px; font-weight: 700;
          letter-spacing: 0.16em; text-transform: uppercase;
          padding: 5px 12px; border-radius: 2px;
          margin-bottom: 20px; width: fit-content;
        ">Documentary</span>
        <h3 style="
          font-family: 'Shippori Mincho', serif;
          font-size: clamp(18px, 2.5vw, 24px);
          font-weight: 600; color: var(--text-hi);
          line-height: 1.45; margin-bottom: 16px;
        ">沖縄戦の10の真実</h3>
        <p class="body-copy" style="font-size: 14px; margin-bottom: 28px;">
          帝国に挟まれた小さな王国の記憶。
          76年間語られてこなかった事実を、映像で記録した代表作。
        </p>
        <a href="https://www.youtube.com/watch?v=2v2vOrz5RXA" target="_blank" rel="noopener" style="
          font-family: 'Noto Sans JP', sans-serif;
          font-size: 12px; color: var(--cyan);
          text-decoration: none;
          border-bottom: 1px solid var(--cyan-border);
          padding-bottom: 2px; width: fit-content;
          letter-spacing: 0.06em;
        ">YouTubeで視聴 →</a>
      </div>
    </div>

    <!-- Sub cards -->
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px;">
      {[
        { tag: '文化', title: '三線伝説 — 琉球の魂', desc: '三本の弦に刻まれた琉球の精神史。' },
        { tag: 'ディアスポラ', title: 'ハワイのウチナーンチュ', desc: '太平洋を渡った沖縄移民と、海を超えて守り継がれたアイデンティティ。' },
        { tag: '歴史', title: '辺野古 — 消えゆく海', desc: '世界有数のサンゴ礁と、それを둘러む静かな問いを記録する。' },
      ].map(({ tag, title, desc }) => (
        <div style="
          background: var(--bg-card);
          border: 1px solid var(--cyan-border);
          border-radius: 6px; padding: 32px 28px;
        ">
          <span style="
            font-family: 'DM Sans', sans-serif;
            font-size: 10px; font-weight: 700;
            letter-spacing: 0.16em; text-transform: uppercase;
            color: var(--cyan); display: block; margin-bottom: 16px;
          ">{tag}</span>
          <h3 style="
            font-family: 'Shippori Mincho', serif;
            font-size: 17px; font-weight: 600;
            color: var(--text-hi); line-height: 1.5; margin-bottom: 12px;
          ">{title}</h3>
          <p class="body-copy" style="font-size: 13px;">{desc}</p>
        </div>
      ))}
    </div>

  </div>
</section>


<!-- ══════════════════════════════════════════
     04  SERVICES
═══════════════════════════════════════════ -->
<section style="padding: 120px 40px; background: var(--bg-base); border-top: 1px solid var(--cyan-border);">
  <div style="max-width: 1200px; margin: 0 auto;">

    <div style="margin-bottom: 64px;">
      <p class="label">Services</p>
      <h2 class="sec-h" style="font-size: clamp(26px, 4vw, 40px);">提供できること</h2>
    </div>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 2px; background: var(--cyan-border); border-radius: 8px; overflow: hidden;">
      {[
        {
          num: '01',
          title: '映像編集',
          body: 'ドキュメンタリー・ショート・企業映像の編集。Adobe Premiere Proによるカラーグレーディング、字幕制作（3言語対応）。',
        },
        {
          num: '02',
          title: 'SNSコンテンツ制作',
          body: 'YouTube Shorts・Reels・TikTok向けの縦型ショート動画。エンゲージメントを最大化する構成と編集。',
        },
        {
          num: '03',
          title: '多言語コンテンツ展開',
          body: '日本語・英語・中国語での字幕翻訳・ナレーション原稿作成。国内コンテンツの海外展開を一貫してサポート。',
        },
        {
          num: '04',
          title: '文化アーカイブ映像',
          body: '伝統行事、無形文化財、家族の記憶。失われる前に残すべきものを、丁寧に記録します。',
        },
      ].map(({ num, title, body }) => (
        <div style="
          background: var(--bg-card);
          padding: 40px 36px;
        ">
          <p style="
            font-family: 'DM Sans', sans-serif;
            font-size: 11px; font-weight: 800;
            letter-spacing: 0.2em; color: var(--cyan);
            margin-bottom: 20px;
          ">{num}</p>
          <h3 style="
            font-family: 'Shippori Mincho', serif;
            font-size: 18px; font-weight: 600;
            color: var(--text-hi); margin-bottom: 14px;
          ">{title}</h3>
          <p class="body-copy" style="font-size: 13px;">{body}</p>
        </div>
      ))}
    </div>

  </div>
</section>


<!-- ══════════════════════════════════════════
     05  CONTACT
═══════════════════════════════════════════ -->
<section style="
  padding: 120px 40px;
  background: var(--bg-deep);
  border-top: 1px solid var(--cyan-border);
  text-align: center;
  position: relative; overflow: hidden;
">
  <!-- Glow -->
  <div style="
    position: absolute; bottom: -80px; left: 50%; transform: translateX(-50%);
    width: 600px; height: 300px;
    background: radial-gradient(ellipse, rgba(34,211,238,0.08) 0%, transparent 70%);
    pointer-events: none;
  "></div>

  <div style="position: relative; z-index: 1; max-width: 640px; margin: 0 auto;">
    <p class="label" style="text-align: center;">Contact</p>
    <h2 class="sec-h" style="font-size: clamp(28px, 4.5vw, 48px); margin-bottom: 20px;">
      まず、話しましょう。
    </h2>
    <p class="body-copy" style="font-size: 15px; margin-bottom: 52px;">
      映像制作・SNS運用・文化アーカイブなど、<br>
      どんな小さなご相談でも構いません。<br>
      お気軽にご連絡ください。
    </p>

    <a href="mailto:letsgokinawa@gmail.com" class="btn-cyan" style="margin-bottom: 16px;">
      メールで相談する
    </a>

    <p style="
      font-family: 'Noto Sans JP', sans-serif;
      font-size: 12px; color: var(--text-lo);
      letter-spacing: 0.06em;
    ">letsgokinawa@gmail.com</p>
  </div>
</section>

</LayoutJA>
