---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Video Production Services | Unmuting Ryukyu">

	<!-- HERO -->
	<header style="padding:120px 32px 80px;background:#272736;position:relative;overflow:hidden;border-bottom:1px solid #3a3a5a;">
		<div style="position:absolute;inset:0;background:radial-gradient(circle at 70% 30%, rgba(201,48,44,0.05) 0%, transparent 60%);"></div>
		<div style="position:absolute;right:0;top:-20px;font-family:'DM Sans',sans-serif;font-size:300px;font-weight:900;color:rgba(255,255,255,0.02);line-height:1;user-select:none;pointer-events:none;letter-spacing:-0.1em;">CREATIVE</div>
		
		<div style="max-width:800px;margin:0 auto;position:relative;z-index:1;">
			<p style="color:#c9302c;font-family:'DM Sans',sans-serif;font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:0.3em;margin:0 0 24px 0;">Professional Production</p>
			<h1 style="font-family:'DM Sans',sans-serif;font-size:clamp(40px,8vw,72px);font-weight:800;color:#f5f0e8;margin:0 0 12px 0;line-height:1;letter-spacing:-0.03em;">We Tell Stories</h1>
			<h1 style="font-family:'DM Sans',sans-serif;font-size:clamp(40px,8vw,72px);font-weight:400;color:#c9302c;margin:0 0 36px 0;line-height:1;letter-spacing:-0.03em;">That Matter.</h1>
			<div style="width:56px;height:2px;background:#c8a951;margin-bottom:32px;"></div>
			<p style="color:#9ca3af;font-family:'Inter',serif;font-size:20px;line-height:1.6;margin:0;max-width:600px;">From Okinawa to the world — professional video production rooted in cultural depth and global relevance.</p>
		</div>
	</header>

	<!-- SERVICES LIST -->
	<section style="padding:100px 32px 140px;background:#272736;">
		<div style="max-width:900px;margin:0 auto;">

			<!-- Service 1 -->
			<div style="background:#2d2d50;border:1px solid #3a3a5a;border-left:4px solid #c9302c;padding:60px 52px;margin-bottom:24px;border-radius:4px;transition:border-color 0.2s;">
				<div style="display:flex;align-items:center;gap:20px;margin-bottom:32px;">
					<span style="font-family:'DM Sans',sans-serif;font-size:48px;font-weight:800;color:rgba(201,48,44,0.1);line-height:1;">01</span>
					<h2 style="font-family:'DM Sans',sans-serif;font-size:clamp(24px,4vw,32px);font-weight:800;color:#f5f0e8;margin:0;line-height:1.2;letter-spacing:-0.02em;">Documentary Films</h2>
				</div>
				<p style="color:#9ca3af;font-family:'Inter',serif;font-size:17px;line-height:1.8;margin:0 0 32px 0;">Long-form documentaries that capture the depth of culture, history, and human experience. Ideal for organizations seeking to preserve and share important Okinawan narratives with a global audience.</p>
				<div style="display:flex;flex-wrap:wrap;gap:12px;margin-bottom:40px;">
					<span style="background:#272736;color:#f5f0e8;font-family:'DM Sans',sans-serif;font-size:12px;font-weight:700;padding:8px 18px;border-radius:2px;border:1px solid #3a3a5a;">Research & Scripting</span>
					<span style="background:#272736;color:#f5f0e8;font-family:'DM Sans',sans-serif;font-size:12px;font-weight:700;padding:8px 18px;border-radius:2px;border:1px solid #3a3a5a;">On-site Filming</span>
					<span style="background:#272736;color:#f5f0e8;font-family:'DM Sans',sans-serif;font-size:12px;font-weight:700;padding:8px 18px;border-radius:2px;border:1px solid #3a3a5a;">Post-Production</span>
					<span style="background:#272736;color:#f5f0e8;font-family:'DM Sans',sans-serif;font-size:12px;font-weight:700;padding:8px 18px;border-radius:2px;border:1px solid #3a3a5a;">Multilingual Subtitling</span>
				</div>
				<a href="/contact/" style="text-decoration:none;color:#c8a951;font-family:'DM Sans',sans-serif;font-weight:700;font-size:14px;letter-spacing:0.1em;text-transform:uppercase;border-bottom:1px solid #c8a951;padding-bottom:2px;">Get in touch →</a>
			</div>

			<!-- Service 2 -->
			<div style="background:#2d2d50;border:1px solid #3a3a5a;border-left:4px solid #c8a951;padding:60px 52px;margin-bottom:24px;border-radius:4px;">
				<div style="display:flex;align-items:center;gap:20px;margin-bottom:32px;">
					<span style="font-family:'DM Sans',sans-serif;font-size:48px;font-weight:800;color:rgba(200,169,81,0.1);line-height:1;">02</span>
					<h2 style="font-family:'DM Sans',sans-serif;font-size:clamp(24px,4vw,32px);font-weight:800;color:#f5f0e8;margin:0;line-height:1.2;letter-spacing:-0.02em;">Short-form Strategy</h2>
				</div>
				<p style="color:#9ca3af;font-family:'Inter',serif;font-size:17px;line-height:1.8;margin:0 0 32px 0;">High-impact content for YouTube Shorts, Reels, and TikTok. Designed for maximum reach and algorithm performance, leveraging AI-powered workflows for premium quality at speed.</p>
				<div style="display:flex;flex-wrap:wrap;gap:12px;margin-bottom:40px;">
					<span style="background:#272736;color:#f5f0e8;font-family:'DM Sans',sans-serif;font-size:12px;font-weight:700;padding:8px 18px;border-radius:2px;border:1px solid #3a3a5a;">Vertical Content</span>
					<span style="background:#272736;color:#f5f0e8;font-family:'DM Sans',sans-serif;font-size:12px;font-weight:700;padding:8px 18px;border-radius:2px;border:1px solid #3a3a5a;">AI-Enhanced Editing</span>
					<span style="background:#272736;color:#f5f0e8;font-family:'DM Sans',sans-serif;font-size:12px;font-weight:700;padding:8px 18px;border-radius:2px;border:1px solid #3a3a5a;">Organic Reach</span>
				</div>
				<a href="/contact/" style="text-decoration:none;color:#c8a951;font-family:'DM Sans',sans-serif;font-weight:700;font-size:14px;letter-spacing:0.1em;text-transform:uppercase;border-bottom:1px solid #c8a951;padding-bottom:2px;">Get in touch →</a>
			</div>

			<!-- Service 3 -->
			<div style="background:#2d2d50;border:1px solid #3a3a5a;border-left:4px solid #c9302c;padding:60px 52px;margin-bottom:24px;border-radius:4px;">
				<div style="display:flex;align-items:center;gap:20px;margin-bottom:32px;">
					<span style="font-family:'DM Sans',sans-serif;font-size:48px;font-weight:800;color:rgba(201,48,44,0.1);line-height:1;">03</span>
					<h2 style="font-family:'DM Sans',sans-serif;font-size:clamp(24px,4vw,32px);font-weight:800;color:#f5f0e8;margin:0;line-height:1.2;letter-spacing:-0.02em;">Corporate & PR</h2>
				</div>
				<p style="color:#9ca3af;font-family:'Inter',serif;font-size:17px;line-height:1.8;margin:0 0 32px 0;">Professional coverage for cultural festivals, corporate branding, and promotional campaigns. We bridge the gap between traditional Okinawan values and modern corporate narratives.</p>
				<div style="display:flex;flex-wrap:wrap;gap:12px;margin-bottom:40px;">
					<span style="background:#272736;color:#f5f0e8;font-family:'DM Sans',sans-serif;font-size:12px;font-weight:700;padding:8px 18px;border-radius:2px;border:1px solid #3a3a5a;">Event Coverage</span>
					<span style="background:#272736;color:#f5f0e8;font-family:'DM Sans',sans-serif;font-size:12px;font-weight:700;padding:8px 18px;border-radius:2px;border:1px solid #3a3a5a;">Brand Narratives</span>
					<span style="background:#272736;color:#f5f0e8;font-family:'DM Sans',sans-serif;font-size:12px;font-weight:700;padding:8px 18px;border-radius:2px;border:1px solid #3a3a5a;">Cultural Consul</span>
				</div>
				<a href="/contact/" style="text-decoration:none;color:#c8a951;font-family:'DM Sans',sans-serif;font-weight:700;font-size:14px;letter-spacing:0.1em;text-transform:uppercase;border-bottom:1px solid #c8a951;padding-bottom:2px;">Get in touch →</a>
			</div>
		</div>
	</section>

	<!-- CTA -->
	<section style="padding:100px 32px;background:#2d2d50;border-top:1px solid #3a3a5a;">
		<div style="max-width:800px;margin:0 auto;text-align:center;">
			<p style="color:#c9302c;font-family:'DM Sans',sans-serif;font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:0.25em;margin:0 0 24px 0;">Ready to Start?</p>
			<h2 style="font-family:'DM Sans',sans-serif;font-size:clamp(32px,5vw,48px);font-weight:800;color:#f5f0e8;margin:0 0 24px 0;line-height:1.1;letter-spacing:-0.02em;">Let's tell your story<br><span style="color:#c8a951;">together.</span></h2>
			<p style="color:#9ca3af;font-family:'Inter',serif;font-size:18px;line-height:1.8;margin:0 0 48px 0;max-width:560px;margin-left:auto;margin-right:auto;">From raw footage to a global legacy. We find the right approach for your unique project.</p>
			<a href="/contact/" style="text-decoration:none;display:inline-block;background:#c9302c;color:#f5f0e8;font-family:'DM Sans',sans-serif;font-weight:700;padding:20px 56px;border-radius:4px;font-size:16px;box-shadow:0 10px 20px rgba(201,48,44,0.3);">
				Start a Discussion
			</a>
		</div>
	</section>

</Layout>
