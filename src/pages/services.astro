---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Video Production Services | Unmuting Ryukyu">

	<!-- HERO -->
	<section style="padding:80px 32px 72px;background:#1C2C4F;position:relative;overflow:hidden;border-bottom:4px solid #8B1D25;">
		<div style="position:absolute;top:0;left:0;width:5px;height:100%;background:#8B1D25;"></div>
		<div style="position:absolute;right:-40px;bottom:-20px;font-family:'Shippori Mincho',serif;font-size:200px;font-weight:700;color:rgba(255,255,255,0.03);line-height:1;user-select:none;pointer-events:none;">映</div>
		<div style="max-width:1100px;margin:0 auto;position:relative;z-index:1;">
			<p style="color:#8B1D25;font-family:'Noto Sans JP',sans-serif;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.3em;margin:0 0 24px 0;">Services</p>
			<h1 style="font-family:'Shippori Mincho','Noto Serif JP',serif;font-size:clamp(38px,7vw,72px);font-weight:700;color:#F0EBE3;margin:0 0 12px 0;line-height:1.0;">We Tell Stories</h1>
			<h1 style="font-family:'Shippori Mincho','Noto Serif JP',serif;font-size:clamp(38px,7vw,72px);font-weight:400;color:#8B1D25;margin:0 0 36px 0;line-height:1.0;font-style:italic;">That Matter.</h1>
			<div style="width:56px;height:2px;background:#8B1D25;margin-bottom:32px;"></div>
			<p style="color:#A8B8C8;font-family:'Noto Serif JP',serif;font-size:17px;line-height:1.9;margin:0;max-width:560px;">From Okinawa to the world — professional video production rooted in cultural understanding, multilingual capability, and AI-powered efficiency.</p>
		</div>
	</section>

	<!-- SERVICES LIST -->
	<section style="padding:80px 32px 96px;background:#F0EBE3;">
		<div style="max-width:900px;margin:0 auto;">

			<!-- Service 1 -->
			<div style="background:#fff;border:1px solid #D0C5BA;border-top:4px solid #8B1D25;padding:48px;margin-bottom:3px;box-shadow:2px 2px 0px #D0C5BA;">
				<div style="display:flex;align-items:center;gap:20px;margin-bottom:24px;">
					<span style="font-family:'Shippori Mincho','Noto Serif JP',serif;font-size:36px;font-weight:700;color:#D0C5BA;line-height:1;">01</span>
					<h2 style="font-family:'Shippori Mincho','Noto Serif JP',serif;font-size:clamp(20px,3vw,28px);font-weight:700;color:#1C2C4F;margin:0;line-height:1.2;">Documentary Films</h2>
				</div>
				<p style="color:#4A3F3B;font-family:'Noto Serif JP',serif;font-size:16px;line-height:1.9;margin:0 0 24px 0;">Long-form documentaries that capture the depth of culture, history, and human experience. Ideal for cultural organizations, government projects, and NPOs seeking to preserve and share important narratives.</p>
				<div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:28px;">
					<span style="border:1px solid #1C2C4F;color:#1C2C4F;font-family:'Noto Sans JP',sans-serif;font-size:12px;font-weight:500;padding:5px 14px;">Research & Scripting</span>
					<span style="border:1px solid #1C2C4F;color:#1C2C4F;font-family:'Noto Sans JP',sans-serif;font-size:12px;font-weight:500;padding:5px 14px;">Filming</span>
					<span style="border:1px solid #1C2C4F;color:#1C2C4F;font-family:'Noto Sans JP',sans-serif;font-size:12px;font-weight:500;padding:5px 14px;">Editing & Post</span>
					<span style="border:1px solid #1C2C4F;color:#1C2C4F;font-family:'Noto Sans JP',sans-serif;font-size:12px;font-weight:500;padding:5px 14px;">Multilingual</span>
				</div>
				<a href="/contact/" style="text-decoration:none;color:#8B1D25;font-family:'Noto Sans JP',sans-serif;font-weight:700;font-size:13px;letter-spacing:0.08em;text-transform:uppercase;">Get in touch →</a>
			</div>

			<!-- Service 2 -->
			<div style="background:#fff;border:1px solid #D0C5BA;border-top:4px solid #1C2C4F;padding:48px;margin-bottom:3px;box-shadow:2px 2px 0px #D0C5BA;">
				<div style="display:flex;align-items:center;gap:20px;margin-bottom:24px;">
					<span style="font-family:'Shippori Mincho','Noto Serif JP',serif;font-size:36px;font-weight:700;color:#D0C5BA;line-height:1;">02</span>
					<h2 style="font-family:'Shippori Mincho','Noto Serif JP',serif;font-size:clamp(20px,3vw,28px);font-weight:700;color:#1C2C4F;margin:0;line-height:1.2;">Short-form Video Production</h2>
				</div>
				<p style="color:#4A3F3B;font-family:'Noto Serif JP',serif;font-size:16px;line-height:1.9;margin:0 0 24px 0;">High-impact content for YouTube Shorts, Instagram Reels, and TikTok. Designed for maximum reach and algorithm performance. AI-powered workflow enables rapid turnaround without sacrificing quality.</p>
				<div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:28px;">
					<span style="border:1px solid #1C2C4F;color:#1C2C4F;font-family:'Noto Sans JP',sans-serif;font-size:12px;font-weight:500;padding:5px 14px;">YouTube Shorts</span>
					<span style="border:1px solid #1C2C4F;color:#1C2C4F;font-family:'Noto Sans JP',sans-serif;font-size:12px;font-weight:500;padding:5px 14px;">Instagram Reels</span>
					<span style="border:1px solid #1C2C4F;color:#1C2C4F;font-family:'Noto Sans JP',sans-serif;font-size:12px;font-weight:500;padding:5px 14px;">TikTok</span>
					<span style="border:1px solid #1C2C4F;color:#1C2C4F;font-family:'Noto Sans JP',sans-serif;font-size:12px;font-weight:500;padding:5px 14px;">AI-Enhanced</span>
				</div>
				<a href="/contact/" style="text-decoration:none;color:#8B1D25;font-family:'Noto Sans JP',sans-serif;font-weight:700;font-size:13px;letter-spacing:0.08em;text-transform:uppercase;">Get in touch →</a>
			</div>

			<!-- Service 3 -->
			<div style="background:#fff;border:1px solid #D0C5BA;border-top:4px solid #8B1D25;padding:48px;margin-bottom:3px;box-shadow:2px 2px 0px #D0C5BA;">
				<div style="display:flex;align-items:center;gap:20px;margin-bottom:24px;">
					<span style="font-family:'Shippori Mincho','Noto Serif JP',serif;font-size:36px;font-weight:700;color:#D0C5BA;line-height:1;">03</span>
					<h2 style="font-family:'Shippori Mincho','Noto Serif JP',serif;font-size:clamp(20px,3vw,28px);font-weight:700;color:#1C2C4F;margin:0;line-height:1.2;">Event & Corporate Video</h2>
				</div>
				<p style="color:#4A3F3B;font-family:'Noto Serif JP',serif;font-size:16px;line-height:1.9;margin:0 0 24px 0;">Professional coverage for cultural festivals, corporate events, weddings, and promotional campaigns. Unique value: Sanshin (Okinawan instrument) performance integration available for ceremonies and events.</p>
				<div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:28px;">
					<span style="border:1px solid #1C2C4F;color:#1C2C4F;font-family:'Noto Sans JP',sans-serif;font-size:12px;font-weight:500;padding:5px 14px;">Event Coverage</span>
					<span style="border:1px solid #1C2C4F;color:#1C2C4F;font-family:'Noto Sans JP',sans-serif;font-size:12px;font-weight:500;padding:5px 14px;">PR & Branding</span>
					<span style="border:1px solid #1C2C4F;color:#1C2C4F;font-family:'Noto Sans JP',sans-serif;font-size:12px;font-weight:500;padding:5px 14px;">Wedding Films</span>
					<span style="border:1px solid #1C2C4F;color:#1C2C4F;font-family:'Noto Sans JP',sans-serif;font-size:12px;font-weight:500;padding:5px 14px;">Sanshin Performance</span>
				</div>
				<a href="/contact/" style="text-decoration:none;color:#8B1D25;font-family:'Noto Sans JP',sans-serif;font-weight:700;font-size:13px;letter-spacing:0.08em;text-transform:uppercase;">Get in touch →</a>
			</div>

			<!-- Service 4 -->
			<div style="background:#fff;border:1px solid #D0C5BA;border-top:4px solid #1C2C4F;padding:48px;margin-bottom:56px;box-shadow:2px 2px 0px #D0C5BA;">
				<div style="display:flex;align-items:center;gap:20px;margin-bottom:24px;">
					<span style="font-family:'Shippori Mincho','Noto Serif JP',serif;font-size:36px;font-weight:700;color:#D0C5BA;line-height:1;">04</span>
					<h2 style="font-family:'Shippori Mincho','Noto Serif JP',serif;font-size:clamp(20px,3vw,28px);font-weight:700;color:#1C2C4F;margin:0;line-height:1.2;">YouTube Channel Management</h2>
				</div>
				<p style="color:#4A3F3B;font-family:'Noto Serif JP',serif;font-size:16px;line-height:1.9;margin:0 0 24px 0;">End-to-end channel operation including editing, thumbnail design, SEO optimization, and growth strategy. Data-driven approach backed by hands-on experience growing a global YouTube presence.</p>
				<div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:28px;">
					<span style="border:1px solid #1C2C4F;color:#1C2C4F;font-family:'Noto Sans JP',sans-serif;font-size:12px;font-weight:500;padding:5px 14px;">Editing</span>
					<span style="border:1px solid #1C2C4F;color:#1C2C4F;font-family:'Noto Sans JP',sans-serif;font-size:12px;font-weight:500;padding:5px 14px;">Thumbnails</span>
					<span style="border:1px solid #1C2C4F;color:#1C2C4F;font-family:'Noto Sans JP',sans-serif;font-size:12px;font-weight:500;padding:5px 14px;">SEO & Strategy</span>
					<span style="border:1px solid #1C2C4F;color:#1C2C4F;font-family:'Noto Sans JP',sans-serif;font-size:12px;font-weight:500;padding:5px 14px;">Monthly Retainer</span>
				</div>
				<a href="/contact/" style="text-decoration:none;color:#8B1D25;font-family:'Noto Sans JP',sans-serif;font-weight:700;font-size:13px;letter-spacing:0.08em;text-transform:uppercase;">Get in touch →</a>
			</div>

		</div>
	</section>

	<!-- CTA -->
	<section style="padding:80px 32px;background:#1C2C4F;border-top:4px solid #8B1D25;">
		<div style="max-width:800px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:40px;">
			<div>
				<p style="color:#8B1D25;font-family:'Noto Sans JP',sans-serif;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.25em;margin:0 0 16px 0;">Ready to Start?</p>
				<h2 style="font-family:'Shippori Mincho','Noto Serif JP',serif;font-size:clamp(24px,4vw,36px);font-weight:700;color:#F0EBE3;margin:0 0 16px 0;line-height:1.2;">Let's tell your story<br>together.</h2>
				<p style="color:#A8B8C8;font-family:'Noto Serif JP',serif;font-size:15px;line-height:1.9;margin:0;max-width:480px;">Whether it's a documentary, social content, or full channel management — we'll find the right approach for your project.</p>
			</div>
			<div>
				<a href="/contact/" style="text-decoration:none;display:inline-block;background:#8B1D25;color:#F0EBE3;font-family:'Noto Sans JP',sans-serif;font-weight:700;padding:18px 44px;border-radius:2px;font-size:14px;letter-spacing:0.06em;white-space:nowrap;">
					Contact Us
				</a>
			</div>
		</div>
	</section>

</Layout>
