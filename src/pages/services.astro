---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Video Production Services | Unmuting Ryukyu">

	<!-- HERO -->
	<header style="padding:120px 32px 80px;background:#1C2C4F;position:relative;overflow:hidden;border-bottom:1px solid rgba(255,255,255,0.12);">
		<div style="position:absolute;inset:0;background:radial-gradient(circle at 70% 30%, rgba(139,29,37,0.08) 0%, transparent 60%);"></div>
		<div style="position:absolute;right:0;top:-20px;font-family:'DM Sans',sans-serif;font-size:300px;font-weight:900;color:rgba(255,255,255,0.02);line-height:1;user-select:none;pointer-events:none;letter-spacing:-0.1em;">CREATIVE</div>

		<div style="max-width:800px;margin:0 auto;position:relative;z-index:1;">
			<p style="color:#8B1D25;font-family:'DM Sans',sans-serif;font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:0.3em;margin:0 0 24px 0;">Professional Production</p>
			<h1 style="font-family:'DM Sans',sans-serif;font-size:clamp(40px,8vw,72px);font-weight:800;color:#F0EBE3;margin:0 0 12px 0;line-height:1;letter-spacing:-0.03em;">We Tell Stories</h1>
			<h1 style="font-family:'DM Sans',sans-serif;font-size:clamp(40px,8vw,72px);font-weight:400;color:#8B1D25;margin:0 0 36px 0;line-height:1;letter-spacing:-0.03em;">That Matter.</h1>
			<div style="width:56px;height:2px;background:#C8A86A;margin-bottom:32px;"></div>
			<p style="color:#A8B8C8;font-family:'Inter',serif;font-size:20px;line-height:1.6;margin:0;max-width:600px;">From Okinawa to the world — professional video production rooted in cultural depth and global relevance.</p>
		</div>
	</header>

	<!-- SERVICES LIST -->
	<section style="padding:100px 32px 140px;background:#F0EBE3;">
		<div style="max-width:900px;margin:0 auto;">

			<!-- Service 1 -->
			<div style="background:#F0EBE3;border:1px solid #D0C5BA;border-left:4px solid #8B1D25;padding:60px 52px;margin-bottom:24px;border-radius:4px;transition:border-color 0.2s;">
				<div style="display:flex;align-items:center;gap:20px;margin-bottom:32px;">
					<span style="font-family:'DM Sans',sans-serif;font-size:48px;font-weight:800;color:rgba(139,29,37,0.08);line-height:1;">01</span>
					<h2 style="font-family:'DM Sans',sans-serif;font-size:clamp(24px,4vw,32px);font-weight:800;color:#1C2C4F;margin:0;line-height:1.2;letter-spacing:-0.02em;">Documentary Films</h2>
				</div>
				<p style="color:#4A3F3B;font-family:'Inter',serif;font-size:17px;line-height:1.8;margin:0 0 32px 0;">Long-form documentaries that capture the depth of culture, history, and human experience. Ideal for organizations seeking to preserve and share important Okinawan narratives with a global audience.</p>
				<div style="display:flex;flex-wrap:wrap;gap:12px;margin-bottom:40px;">
					<span style="background:#E8E2D8;color:#4A3F3B;font-family:'DM Sans',sans-serif;font-size:12px;font-weight:700;padding:8px 18px;border-radius:2px;border:1px solid #D0C5BA;">Research & Scripting</span>
					<span style="background:#E8E2D8;color:#4A3F3B;font-family:'DM Sans',sans-serif;font-size:12px;font-weight:700;padding:8px 18px;border-radius:2px;border:1px solid #D0C5BA;">On-site Filming</span>
					<span style="background:#E8E2D8;color:#4A3F3B;font-family:'DM Sans',sans-serif;font-size:12px;font-weight:700;padding:8px 18px;border-radius:2px;border:1px solid #D0C5BA;">Post-Production</span>
					<span style="background:#E8E2D8;color:#4A3F3B;font-family:'DM Sans',sans-serif;font-size:12px;font-weight:700;padding:8px 18px;border-radius:2px;border:1px solid #D0C5BA;">Multilingual Subtitling</span>
				</div>
				<a href="/contact/" style="text-decoration:none;color:#C8A86A;font-family:'DM Sans',sans-serif;font-weight:700;font-size:14px;letter-spacing:0.1em;text-transform:uppercase;border-bottom:1px solid #C8A86A;padding-bottom:2px;">Get in touch →</a>
			</div>

			<!-- Service 2 -->
			<div style="background:#F0EBE3;border:1px solid #D0C5BA;border-left:4px solid #C8A86A;padding:60px 52px;margin-bottom:24px;border-radius:4px;">
				<div style="display:flex;align-items:center;gap:20px;margin-bottom:32px;">
					<span style="font-family:'DM Sans',sans-serif;font-size:48px;font-weight:800;color:rgba(200,168,106,0.12);line-height:1;">02</span>
					<h2 style="font-family:'DM Sans',sans-serif;font-size:clamp(24px,4vw,32px);font-weight:800;color:#1C2C4F;margin:0;line-height:1.2;letter-spacing:-0.02em;">Short-form Strategy</h2>
				</div>
				<p style="color:#4A3F3B;font-family:'Inter',serif;font-size:17px;line-height:1.8;margin:0 0 32px 0;">High-impact content for YouTube Shorts, Reels, and TikTok. Designed for maximum reach and algorithm performance, leveraging AI-powered workflows for premium quality at speed.</p>
				<div style="display:flex;flex-wrap:wrap;gap:12px;margin-bottom:40px;">
					<span style="background:#E8E2D8;color:#4A3F3B;font-family:'DM Sans',sans-serif;font-size:12px;font-weight:700;padding:8px 18px;border-radius:2px;border:1px solid #D0C5BA;">Vertical Content</span>
					<span style="background:#E8E2D8;color:#4A3F3B;font-family:'DM Sans',sans-serif;font-size:12px;font-weight:700;padding:8px 18px;border-radius:2px;border:1px solid #D0C5BA;">AI-Enhanced Editing</span>
					<span style="background:#E8E2D8;color:#4A3F3B;font-family:'DM Sans',sans-serif;font-size:12px;font-weight:700;padding:8px 18px;border-radius:2px;border:1px solid #D0C5BA;">Organic Reach</span>
				</div>
				<a href="/contact/" style="text-decoration:none;color:#C8A86A;font-family:'DM Sans',sans-serif;font-weight:700;font-size:14px;letter-spacing:0.1em;text-transform:uppercase;border-bottom:1px solid #C8A86A;padding-bottom:2px;">Get in touch →</a>
			</div>

			<!-- Service 3 -->
			<div style="background:#F0EBE3;border:1px solid #D0C5BA;border-left:4px solid #8B1D25;padding:60px 52px;margin-bottom:24px;border-radius:4px;">
				<div style="display:flex;align-items:center;gap:20px;margin-bottom:32px;">
					<span style="font-family:'DM Sans',sans-serif;font-size:48px;font-weight:800;color:rgba(139,29,37,0.08);line-height:1;">03</span>
					<h2 style="font-family:'DM Sans',sans-serif;font-size:clamp(24px,4vw,32px);font-weight:800;color:#1C2C4F;margin:0;line-height:1.2;letter-spacing:-0.02em;">Corporate & PR</h2>
				</div>
				<p style="color:#4A3F3B;font-family:'Inter',serif;font-size:17px;line-height:1.8;margin:0 0 32px 0;">Professional coverage for cultural festivals, corporate branding, and promotional campaigns. We bridge the gap between traditional Okinawan values and modern corporate narratives.</p>
				<div style="display:flex;flex-wrap:wrap;gap:12px;margin-bottom:40px;">
					<span style="background:#E8E2D8;color:#4A3F3B;font-family:'DM Sans',sans-serif;font-size:12px;font-weight:700;padding:8px 18px;border-radius:2px;border:1px solid #D0C5BA;">Event Coverage</span>
					<span style="background:#E8E2D8;color:#4A3F3B;font-family:'DM Sans',sans-serif;font-size:12px;font-weight:700;padding:8px 18px;border-radius:2px;border:1px solid #D0C5BA;">Brand Narratives</span>
					<span style="background:#E8E2D8;color:#4A3F3B;font-family:'DM Sans',sans-serif;font-size:12px;font-weight:700;padding:8px 18px;border-radius:2px;border:1px solid #D0C5BA;">Cultural Consul</span>
				</div>
				<a href="/contact/" style="text-decoration:none;color:#C8A86A;font-family:'DM Sans',sans-serif;font-weight:700;font-size:14px;letter-spacing:0.1em;text-transform:uppercase;border-bottom:1px solid #C8A86A;padding-bottom:2px;">Get in touch →</a>
			</div>
		</div>
	</section>

	<!-- CTA -->
	<section style="padding:100px 32px;background:#1C2C4F;border-top:1px solid rgba(255,255,255,0.12);">
		<div style="max-width:800px;margin:0 auto;text-align:center;">
			<p style="color:#8B1D25;font-family:'DM Sans',sans-serif;font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:0.25em;margin:0 0 24px 0;">Ready to Start?</p>
			<h2 style="font-family:'DM Sans',sans-serif;font-size:clamp(32px,5vw,48px);font-weight:800;color:#F0EBE3;margin:0 0 24px 0;line-height:1.1;letter-spacing:-0.02em;">Let's tell your story<br><span style="color:#C8A86A;">together.</span></h2>
			<p style="color:#A8B8C8;font-family:'Inter',serif;font-size:18px;line-height:1.8;margin:0 0 48px 0;max-width:560px;margin-left:auto;margin-right:auto;">From raw footage to a global legacy. We find the right approach for your unique project.</p>
			<a href="/contact/" style="text-decoration:none;display:inline-block;background:#8B1D25;color:#F0EBE3;font-family:'DM Sans',sans-serif;font-weight:700;padding:20px 56px;border-radius:4px;font-size:16px;box-shadow:0 10px 20px rgba(139,29,37,0.4);">
				Start a Discussion
			</a>
		</div>
	</section>

</Layout>
