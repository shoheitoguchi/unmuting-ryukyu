---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Unmuting Ryukyu — Revealing Okinawa's Hidden Stories">

	<!-- HERO -->
	<section style="min-height:calc(100vh - 72px);display:flex;align-items:center;position:relative;overflow:hidden;padding:80px 32px;">
		<!-- Background Image with Blur -->
		<div style="position:absolute;inset:-15px;z-index:0;background-image:url('/images/shuri-castle.jpg');background-size:cover;background-position:center;filter:blur(8px);opacity:0.4;"></div>
		<!-- Sumi-iro Overlay -->
		<div style="position:absolute;inset:0;z-index:1;background:linear-gradient(to bottom, rgba(30,30,30,0.88) 0%, rgba(30,30,30,0.72) 50%, rgba(30,30,30,0.88) 100%);"></div>
		<!-- Subtle Red Glow -->
		<div style="position:absolute;bottom:0;right:0;width:60%;height:60%;z-index:2;background:radial-gradient(circle at 70% 70%, rgba(201,48,44,0.15) 0%, transparent 70%);pointer-events:none;"></div>

		<!-- Left accent bar (Bingata Red) -->
		<div style="position:absolute;top:0;left:0;width:6px;height:100%;background:#c9302c;z-index:3;"></div>

		<div style="max-width:1200px;margin:0 auto;width:100%;position:relative;z-index:4;">
			<p style="color:#c8a951;font-family:'DM Sans', sans-serif;font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:0.3em;margin:0 0 32px 0;padding-left:16px;border-left:3px solid #c9302c;">A Documentary Series by Shohei Toguchi</p>
			
			<h1 style="font-family:'DM Sans', sans-serif;font-size:clamp(64px,10vw,120px);font-weight:900;line-height:0.9;margin:0;letter-spacing:-0.02em;text-transform:uppercase;color:#f5f0e8;">
				UNMUTING<br/>
				<span style="color:#c9302c;">RYUKYU</span>
			</h1>

			<div style="width:64px;height:2px;background:#c9302c;margin:40px 0;"></div>
			
			<p style="font-family:'Inter', sans-serif;font-size:18px;color:#9ca3af;line-height:1.8;margin:0 0 56px 0;max-width:540px;">
				Revealing the hidden stories of Okinawa's struggle, culture, and resilience through documentary filmmaking.
			</p>
			
			<div style="display:flex;gap:20px;flex-wrap:wrap;">
				<a href="https://www.youtube.com/@letsgokinawa" target="_blank" rel="noopener noreferrer" style="text-decoration:none;display:inline-flex;align-items:center;gap:12px;background:#c9302c;color:#f5f0e8;font-family:'DM Sans', sans-serif;font-weight:700;padding:18px 36px;border-radius:4px;font-size:15px;letter-spacing:0.02em;box-shadow:0 10px 20px rgba(201,48,44,0.25);">
					<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
					Watch on YouTube
				</a>
				<a href="/videos/" style="text-decoration:none;display:inline-flex;align-items:center;gap:8px;border:1px solid rgba(245,240,232,0.2);color:#f5f0e8;font-family:'DM Sans', sans-serif;font-weight:500;padding:18px 36px;border-radius:4px;font-size:15px;letter-spacing:0.02em;backdrop-filter:blur(4px);">
					Watch Documentaries →
				</a>
			</div>
		</div>
	</section>

	<!-- FEATURED VIDEO -->
	<section style="padding:120px 32px;background:#232340;border-bottom:1px solid #333348;">
		<div style="max-width:1100px;margin:0 auto;">
			<div style="display:flex;align-items:center;gap:20px;margin-bottom:64px;">
				<div style="width:6px;height:32px;background:#c9302c;"></div>
				<div>
					<p style="color:#c9302c;font-family:'DM Sans', sans-serif;font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:0.2em;margin:0 0 8px 0;">Featured Work</p>
					<h2 style="font-family:'DM Sans', sans-serif;font-size:clamp(32px,5vw,48px);font-weight:800;color:#f5f0e8;margin:0;letter-spacing:-0.01em;">Operation Iceberg</h2>
				</div>
			</div>
			
			<div style="display:grid;grid-template-columns:repeat(auto-fit, minmax(300px, 1fr));gap:64px;align-items:center;">
				<div style="background:#000;border:1px solid #2a2a3e;position:relative;overflow:hidden;border-radius:4px;box-shadow:20px 20px 0px rgba(201,48,44,0.1);">
					<div style="position:relative;padding-bottom:56.25%;height:0;">
						<iframe style="position:absolute;top:0;left:0;width:100%;height:100%;border:0;" src="https://www.youtube.com/embed/2v2vOrz5RXA" title="Battle of Okinawa" allow="accelerometer;autoplay;clipboard-write;encrypted-media;gyroscope;picture-in-picture" allowfullscreen></iframe>
					</div>
				</div>
				<div>
					<span style="display:inline-block;background:#c9302c;color:#f5f0e8;font-family:'DM Sans', sans-serif;font-size:11px;font-weight:700;padding:6px 16px;border-radius:2px;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:24px;">Deep Documentary</span>
					<h3 style="font-family:'DM Sans', sans-serif;font-size:28px;font-weight:800;color:#f5f0e8;margin:0 0 24px 0;line-height:1.3;">10 Realities of the Battle of Okinawa</h3>
					<p style="color:#9ca3af;font-family:'Inter', sans-serif;font-size:16px;line-height:1.8;margin:0 0 32px 0;">A peaceful kingdom crushed between empires. This documentary explores the pivotal Battle of Okinawa and its lasting impact on the island's soul.</p>
					<a href="/blog/battle-of-okinawa/" style="text-decoration:none;color:#c8a951;font-family:'DM Sans', sans-serif;font-weight:700;font-size:14px;letter-spacing:0.05em;display:inline-flex;align-items:center;gap:8px;text-transform:uppercase;border-bottom:1px solid #c8a951;padding-bottom:4px;">
						Read the Full Story →
					</a>
				</div>
			</div>
		</div>
	</section>

	<!-- MISSION SECTION -->
	<section style="padding:120px 32px;background:#1e1e1e;position:relative;overflow:hidden;border-bottom:1px solid #333348;">
		<div style="position:absolute;right:-60px;top:50%;transform:translateY(-50%);font-family:'Shippori Mincho', serif;font-size:320px;font-weight:800;color:rgba(200,169,81,0.03);line-height:1;user-select:none;pointer-events:none;">琉</div>
		<div style="max-width:900px;margin:0 auto;position:relative;z-index:1;">
			<div style="display:flex;align-items:center;gap:20px;margin-bottom:48px;">
				<div style="width:6px;height:32px;background:#c9302c;"></div>
				<p style="color:#c9302c;font-family:'DM Sans', sans-serif;font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:0.2em;margin:0;">The Mission</p>
			</div>
			<h2 style="font-family:'DM Sans', sans-serif;font-size:clamp(32px,5vw,56px);font-weight:800;color:#f5f0e8;margin:0 0 40px 0;line-height:1.1;letter-spacing:-0.02em;">We tell stories<br/>that matter.</h2>
			<p style="color:#9ca3af;font-family:'Inter', sans-serif;font-size:18px;line-height:1.9;margin:0 0 32px 0;max-width:720px;">
				Okinawa's history has been silenced for too long. Through filmmaking and storytelling, we bring to light the struggle, resilience, and beauty of Ryukyuan culture — connecting the global Uchinanchu community with their roots.
			</p>
			<p style="color:#c8a951;font-family:'Inter', sans-serif;font-size:20px;line-height:1.8;margin:0 0 64px 0;max-width:720px;font-style:italic;font-weight:300;">
				"Language is peace. To know a culture's tongue is to respect its soul."
			</p>
			<div style="display:flex;gap:24px;flex-wrap:wrap;align-items:center;">
				<a href="/about/" style="text-decoration:none;background:#f5f0e8;color:#111111;font-family:'DM Sans', sans-serif;font-weight:700;padding:16px 36px;border-radius:4px;font-size:14px;letter-spacing:0.02em;">
					About Shohei →
				</a>
				<a href="/services/" style="text-decoration:none;color:#c8a951;font-family:'DM Sans', sans-serif;font-weight:700;font-size:14px;letter-spacing:0.05em;text-transform:uppercase;">
					Our Services
				</a>
			</div>
		</div>
	</section>

	<!-- SERVICES PREVIEW -->
	<section style="padding:120px 32px;background:#232340;">
		<div style="max-width:1200px;margin:0 auto;">
			<div style="display:flex;align-items:center;gap:20px;margin-bottom:64px;">
				<div style="width:6px;height:32px;background:#c9302c;"></div>
				<h2 style="font-family:'DM Sans', sans-serif;font-size:clamp(32px,5vw,48px);font-weight:800;color:#f5f0e8;margin:0;letter-spacing:-0.01em;">Services</h2>
			</div>
			
			<div style="display:grid;grid-template-columns:repeat(auto-fit, minmax(320px, 1fr));gap:32px;">
				<div style="background:#1e1e1e;padding:48px;border:1px solid #2a2a3e;border-radius:4px;transition:border-color 0.3s;">
					<p style="color:#c8a951;font-family:'DM Sans', sans-serif;font-size:12px;font-weight:800;letter-spacing:0.2em;margin:0 0 24px 0;">01</p>
					<h3 style="font-family:'DM Sans', sans-serif;font-size:24px;font-weight:700;color:#f5f0e8;margin:0 0 16px 0;">Documentary Films</h3>
					<p style="color:#9ca3af;font-family:'Inter', sans-serif;font-size:15px;line-height:1.8;margin:0;">Long-form storytelling that captures culture and history with cinematic depth and global perspective.</p>
				</div>
				<div style="background:#1e1e1e;padding:48px;border:1px solid #c9302c;border-radius:4px;">
					<p style="color:#c8a951;font-family:'DM Sans', sans-serif;font-size:12px;font-weight:800;letter-spacing:0.2em;margin:0 0 24px 0;">02</p>
					<h3 style="font-family:'DM Sans', sans-serif;font-size:24px;font-weight:700;color:#f5f0e8;margin:0 0 16px 0;">Short-form Content</h3>
					<p style="color:#9ca3af;font-family:'Inter', sans-serif;font-size:15px;line-height:1.8;margin:0;">High-impact Reels, Shorts, and TikTok content designed for maximum engagement and reach.</p>
				</div>
				<div style="background:#1e1e1e;padding:48px;border:1px solid #2a2a3e;border-radius:4px;">
					<p style="color:#c8a951;font-family:'DM Sans', sans-serif;font-size:12px;font-weight:800;letter-spacing:0.2em;margin:0 0 24px 0;">03</p>
					<h3 style="font-family:'DM Sans', sans-serif;font-size:24px;font-weight:700;color:#f5f0e8;margin:0 0 16px 0;">Corporate & Events</h3>
					<p style="color:#9ca3af;font-family:'Inter', sans-serif;font-size:15px;line-height:1.8;margin:0;">Cinematic coverage for events and brands that need more than just recording—they need a story.</p>
				</div>
			</div>
			
			<div style="margin-top:64px;text-align:center;">
				<a href="/services/" style="text-decoration:none;color:#f5f0e8;font-family:'DM Sans', sans-serif;font-weight:700;font-size:14px;letter-spacing:0.1em;text-transform:uppercase;border-bottom:1px solid #c9302c;padding-bottom:6px;">View All Service Details →</a>
			</div>
		</div>
	</section>

</Layout>
