---
// Language Gate — no shared layout, standalone cinematic entrance
---
<!doctype html>
<html lang="mul">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Shohei Toguchi — Documentary Filmmaker & Video Editor. Okinawa's stories to the world." />
  <title>Shohei Toguchi | Documentary Filmmaker & Video Editor</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&family=Noto+Sans+JP:wght@300;400;700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    html, body {
      width: 100%;
      height: 100%;
      overflow: hidden;
      background: #0E2330;
    }

    /* ── Carousel background ── */
    .bg {
      position: fixed;
      inset: 0;
      z-index: 0;
    }

    .slide {
      position: absolute;
      inset: 0;
      background-size: cover;
      background-position: center;
      opacity: 0;
      animation: carousel 21s infinite;
    }

    /* Using the existing image; swap these once you add more photos */
    .slide:nth-child(1) {
      background-image: url('/images/shuri-castle.jpg');
      animation-delay: 0s;
    }
    .slide:nth-child(2) {
      background-image: url('/images/shuri-castle.jpg');
      filter: hue-rotate(10deg) brightness(0.95);
      animation-delay: 7s;
    }
    .slide:nth-child(3) {
      background-image: url('/images/shuri-castle.jpg');
      filter: hue-rotate(-10deg) brightness(0.9);
      animation-delay: 14s;
    }

    @keyframes carousel {
      0%       { opacity: 0; transform: scale(1.06); }
      6%       { opacity: 1; transform: scale(1.03); }
      30%      { opacity: 1; transform: scale(1.00); }
      38%, 100%{ opacity: 0; transform: scale(0.97); }
    }

    /* ── Dark gradient overlay ── */
    .overlay {
      position: fixed;
      inset: 0;
      z-index: 1;
      background:
        linear-gradient(to right,  rgba(14,35,48,0.85) 0%, rgba(14,35,48,0.50) 60%, rgba(14,35,48,0.75) 100%),
        linear-gradient(to bottom, rgba(14,35,48,0.60) 0%, rgba(14,35,48,0.25) 50%, rgba(14,35,48,0.80) 100%);
    }

    /* ── Water-blue accent line (left edge) ── */
    .accent-v {
      position: fixed;
      top: 0; left: 0;
      width: 4px; height: 100vh;
      background: linear-gradient(to bottom, transparent 0%, #7EC8E3 40%, #5BAAC8 60%, transparent 100%);
      z-index: 5;
    }

    /* ── Top bar ── */
    .topbar {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 20;
      padding: 24px 40px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      opacity: 0;
      animation: fadeIn 1s 0.2s forwards;
    }

    .logo {
      font-family: 'DM Sans', sans-serif;
      font-size: 14px;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: #7EC8E3;
      text-decoration: none;
    }

    .topbar-social {
      display: flex;
      gap: 24px;
    }

    .topbar-social a {
      color: rgba(245,250,251,0.45);
      font-family: 'DM Sans', sans-serif;
      font-size: 11px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      text-decoration: none;
      transition: color 0.2s;
    }

    .topbar-social a:hover { color: #7EC8E3; }

    /* ── Main gate content ── */
    .gate {
      position: fixed;
      inset: 0;
      z-index: 10;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 32px;
      text-align: center;
    }

    .eyebrow {
      font-family: 'DM Sans', sans-serif;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      color: #7EC8E3;
      margin-bottom: 28px;
      opacity: 0;
      animation: fadeUp 0.9s 0.5s forwards;
    }

    .name {
      font-family: 'DM Sans', sans-serif;
      font-size: clamp(52px, 9vw, 108px);
      font-weight: 900;
      letter-spacing: -0.03em;
      line-height: 0.92;
      color: #F5FAFB;
      margin-bottom: 10px;
      opacity: 0;
      animation: fadeUp 0.9s 0.7s forwards;
    }

    .name span {
      color: #7EC8E3;
      display: block;
    }

    .tagline {
      font-family: 'Noto Sans JP', 'DM Sans', sans-serif;
      font-size: clamp(13px, 1.8vw, 16px);
      font-weight: 300;
      letter-spacing: 0.12em;
      color: rgba(245,250,251,0.55);
      margin-bottom: 72px;
      opacity: 0;
      animation: fadeUp 0.9s 0.9s forwards;
    }

    /* ── Language selector ── */
    .lang-grid {
      display: flex;
      align-items: stretch;
      gap: 0;
      opacity: 0;
      animation: fadeUp 0.9s 1.1s forwards;
    }

    .lang-btn {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 10px;
      padding: 28px 48px;
      border: 1px solid rgba(126,200,227,0.25);
      background: rgba(14,35,48,0.45);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      color: #F5FAFB;
      text-decoration: none;
      transition: all 0.35s ease;
      min-width: 180px;
    }

    .lang-btn:first-child { border-radius: 6px 0 0 6px; }
    .lang-btn:last-child  { border-radius: 0 6px 6px 0; }

    .lang-btn:hover {
      background: rgba(126,200,227,0.18);
      border-color: #7EC8E3;
      transform: translateY(-6px);
      box-shadow: 0 16px 40px rgba(126,200,227,0.15);
      z-index: 1;
    }

    .lang-btn.featured {
      border-color: rgba(126,200,227,0.55);
      background: rgba(126,200,227,0.10);
    }

    .lang-btn .lg {
      font-family: 'DM Sans', sans-serif;
      font-size: 24px;
      font-weight: 700;
    }

    .lang-btn .sm {
      font-family: 'DM Sans', sans-serif;
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(245,250,251,0.4);
    }

    .lang-btn:hover .sm { color: #7EC8E3; }

    /* ── Bottom strip ── */
    .bottom-strip {
      position: fixed;
      bottom: 0; left: 0; right: 0;
      z-index: 20;
      padding: 20px 40px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-top: 1px solid rgba(126,200,227,0.10);
      opacity: 0;
      animation: fadeIn 1s 1.4s forwards;
    }

    .bottom-strip p {
      font-family: 'DM Sans', sans-serif;
      font-size: 11px;
      color: rgba(245,250,251,0.30);
      letter-spacing: 0.08em;
    }

    /* ── Animations ── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(24px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    @keyframes fadeIn {
      from { opacity: 0; }
      to   { opacity: 1; }
    }

    /* ── Responsive ── */
    @media (max-width: 600px) {
      .lang-grid {
        flex-direction: column;
        width: 100%;
        max-width: 280px;
      }
      .lang-btn {
        border-radius: 0;
        padding: 20px 32px;
      }
      .lang-btn:first-child { border-radius: 6px 6px 0 0; }
      .lang-btn:last-child  { border-radius: 0 0 6px 6px; }
      .topbar-social { display: none; }
    }
  </style>
</head>
<body>

  <!-- Carousel -->
  <div class="bg">
    <div class="slide"></div>
    <div class="slide"></div>
    <div class="slide"></div>
  </div>

  <!-- Overlays -->
  <div class="overlay"></div>
  <div class="accent-v"></div>

  <!-- Top bar -->
  <header class="topbar">
    <span class="logo">Unmuting Ryukyu</span>
    <nav class="topbar-social">
      <a href="https://www.youtube.com/@letsgokinawa" target="_blank" rel="noopener">YouTube</a>
      <a href="https://www.instagram.com/unmutingryukyu/" target="_blank" rel="noopener">Instagram</a>
      <a href="https://x.com/letsgokinawa" target="_blank" rel="noopener">X</a>
    </nav>
  </header>

  <!-- Gate -->
  <main class="gate">
    <p class="eyebrow">Documentary Filmmaker &amp; Video Editor</p>

    <h1 class="name">
      SHOHEI
      <span>TOGUCHI</span>
    </h1>

    <p class="tagline">沖縄・琉球の物語を世界へ &nbsp;|&nbsp; Okinawa's stories to the world</p>

    <div class="lang-grid">
      <a href="/en/" class="lang-btn featured">
        <span class="lg">English</span>
        <span class="sm">EN — Global</span>
      </a>
      <a href="/ja/" class="lang-btn">
        <span class="lg" style="font-family:'Noto Sans JP',sans-serif;font-weight:700;">日本語</span>
        <span class="sm">JA — 日本向け</span>
      </a>
      <a href="/zh/" class="lang-btn">
        <span class="lg">中文</span>
        <span class="sm">ZH — Coming soon</span>
      </a>
    </div>
  </main>

  <!-- Bottom strip -->
  <footer class="bottom-strip">
    <p>unmutingryukyu.com</p>
    <p>&copy; 2026 Shohei Toguchi. All rights reserved.</p>
  </footer>

</body>
</html>
