---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Videos | Unmuting Ryukyu">

	<!-- PAGE HEADER -->
	<section style="padding:72px 32px 56px;background:#1C2C4F;position:relative;overflow:hidden;border-bottom:4px solid #8B1D25;">
		<div style="position:absolute;top:0;left:0;width:5px;height:100%;background:#8B1D25;"></div>
		<div style="max-width:1100px;margin:0 auto;position:relative;z-index:1;">
			<p style="color:#8B1D25;font-family:'Noto Sans JP',sans-serif;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.3em;margin:0 0 16px 0;">Documentary Archive</p>
			<h1 style="font-family:'Shippori Mincho','Noto Serif JP',serif;font-size:clamp(36px,6vw,64px);font-weight:700;color:#F0EBE3;margin:0;line-height:1.05;">Videos</h1>
		</div>
	</section>

	<!-- VIDEO GRID -->
	<section style="padding:80px 32px;background:#F0EBE3;">
		<div style="max-width:1000px;margin:0 auto;">

			<!-- Video Card 1 -->
			<div style="background:#fff;border:1px solid #D0C5BA;margin-bottom:48px;box-shadow:4px 4px 0px #1C2C4F;overflow:hidden;">
				<div style="position:relative;padding-bottom:56.25%;height:0;background:#0a0a0a;">
					<iframe style="position:absolute;top:0;left:0;width:100%;height:100%;border:0;" src="https://www.youtube.com/embed/2v2vOrz5RXA" title="Battle of Okinawa" allow="accelerometer;autoplay;clipboard-write;encrypted-media;gyroscope;picture-in-picture" allowfullscreen></iframe>
				</div>
				<div style="padding:36px;border-top:3px solid #8B1D25;">
					<div style="display:flex;align-items:center;gap:12px;margin-bottom:16px;">
						<span style="display:inline-block;background:#8B1D25;color:#F0EBE3;font-family:'Noto Sans JP',sans-serif;font-size:10px;font-weight:700;padding:4px 12px;letter-spacing:0.1em;text-transform:uppercase;">Documentary</span>
						<span style="color:#8B8078;font-family:'Noto Sans JP',sans-serif;font-size:12px;">2025</span>
					</div>
					<h2 style="font-family:'Shippori Mincho','Noto Serif JP',serif;font-size:clamp(18px,3vw,26px);font-weight:700;color:#1C2C4F;margin:0 0 14px 0;line-height:1.35;">Battle of Okinawa: 10 Realities You Never Know</h2>
					<p style="color:#4A3F3B;font-family:'Noto Serif JP',serif;font-size:15px;line-height:1.9;margin:0 0 28px 0;max-width:680px;">A documentary exploring the pivotal Battle of Okinawa and its lasting impact on the island's history, people, and culture. Revealing 10 historical truths that mainstream history overlooked.</p>
					<div style="display:flex;gap:14px;flex-wrap:wrap;align-items:center;">
						<a href="https://www.youtube.com/@letsgokinawa?sub_confirmation=1" target="_blank" rel="noopener noreferrer" style="text-decoration:none;display:inline-flex;align-items:center;gap:8px;background:#8B1D25;color:#F0EBE3;font-family:'Noto Sans JP',sans-serif;font-weight:700;padding:12px 24px;border-radius:2px;font-size:13px;letter-spacing:0.05em;">
							<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
							Subscribe
						</a>
						<a href="/blog/battle-of-okinawa/" style="text-decoration:none;color:#8B1D25;font-family:'Noto Sans JP',sans-serif;font-weight:700;font-size:12px;letter-spacing:0.08em;text-transform:uppercase;">Read Article →</a>
					</div>
				</div>
			</div>

			<!-- Coming Soon -->
			<div style="background:#E8E2D8;border:1px solid #D0C5BA;padding:64px 40px;text-align:center;border-top:3px solid #1C2C4F;">
				<p style="color:#1C2C4F;font-family:'Noto Sans JP',sans-serif;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.3em;margin:0 0 20px 0;">Coming Soon</p>
				<h3 style="font-family:'Shippori Mincho','Noto Serif JP',serif;font-size:26px;font-weight:700;color:#1C2C4F;margin:0 0 16px 0;">More Documentaries in Production</h3>
				<p style="color:#4A3F3B;font-family:'Noto Serif JP',serif;font-size:15px;line-height:1.9;margin:0 0 36px auto;max-width:520px;">Subscribe to be the first to know when new documentaries are published. New videos every month.</p>
				<a href="https://www.youtube.com/@letsgokinawa?sub_confirmation=1" target="_blank" rel="noopener noreferrer" style="text-decoration:none;display:inline-flex;align-items:center;gap:8px;background:#8B1D25;color:#F0EBE3;font-family:'Noto Sans JP',sans-serif;font-weight:700;padding:14px 36px;border-radius:2px;font-size:13px;letter-spacing:0.05em;">
					<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
					Subscribe on YouTube
				</a>
			</div>

		</div>
	</section>

</Layout>
