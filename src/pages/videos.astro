---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Videos | Unmuting Ryukyu">

	<!-- PAGE HEADER -->
	<header style="padding:120px 32px 80px;background:#1C2C4F;position:relative;overflow:hidden;border-bottom:1px solid rgba(255,255,255,0.12);">
		<div style="position:absolute;inset:0;background:radial-gradient(circle at 70% 30%, rgba(139,29,37,0.08) 0%, transparent 60%);"></div>
		<div style="position:absolute;right:0;top:-20px;font-family:'DM Sans',sans-serif;font-size:300px;font-weight:900;color:rgba(255,255,255,0.02);line-height:1;user-select:none;pointer-events:none;letter-spacing:-0.1em;">FILMS</div>

		<div style="max-width:800px;margin:0 auto;position:relative;z-index:1;">
			<p style="color:#8B1D25;font-family:'DM Sans',sans-serif;font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:0.3em;margin:0 0 24px 0;">The Documentary Archive</p>
			<h1 style="font-family:'DM Sans',sans-serif;font-size:clamp(40px,8vw,72px);font-weight:800;color:#F0EBE3;margin:0;line-height:1;letter-spacing:-0.03em;">Videos</h1>
		</div>
	</header>

	<!-- VIDEO GRID -->
	<section style="padding:100px 32px 140px;background:#F0EBE3;">
		<div style="max-width:1000px;margin:0 auto;">

			<!-- Video Card 1 -->
			<div style="background:#fff;border:1px solid #D0C5BA;margin-bottom:64px;overflow:hidden;border-radius:4px;box-shadow:0 4px 20px rgba(74,63,59,0.08);">
				<div style="position:relative;padding-bottom:56.25%;height:0;background:#000;">
					<iframe style="position:absolute;top:0;left:0;width:100%;height:100%;border:0;" src="https://www.youtube.com/embed/2v2vOrz5RXA" title="Battle of Okinawa" allow="accelerometer;autoplay;clipboard-write;encrypted-media;gyroscope;picture-in-picture" allowfullscreen></iframe>
				</div>
				<div style="padding:48px;border-top:4px solid #8B1D25;">
					<div style="display:flex;align-items:center;gap:16px;margin-bottom:24px;">
						<span style="display:inline-block;background:#8B1D25;color:#F0EBE3;font-family:'DM Sans',sans-serif;font-size:11px;font-weight:700;padding:6px 16px;border-radius:2px;letter-spacing:0.1em;text-transform:uppercase;">Documentary</span>
						<span style="color:#4A3F3B;font-family:'Inter',sans-serif;font-size:13px;">March 2026</span>
					</div>
					<h2 style="font-family:'DM Sans',sans-serif;font-size:clamp(22px,3vw,32px);font-weight:800;color:#1C2C4F;margin:0 0 20px 0;line-height:1.2;letter-spacing:-0.01em;">Operation Iceberg: 10 Realities You Never Knew</h2>
					<p style="color:#4A3F3B;font-family:'Inter',serif;font-size:17px;line-height:1.8;margin:0 0 32px 0;max-width:720px;">A documentary exploring the pivotal Battle of Okinawa and its lasting impact on the island's history, people, and culture. Revealing historical truths that mainstream history often overlooks.</p>
					<div style="display:flex;gap:20px;flex-wrap:wrap;align-items:center;">
						<a href="https://www.youtube.com/@letsgokinawa" target="_blank" rel="noopener noreferrer" style="text-decoration:none;display:inline-flex;align-items:center;gap:12px;background:#8B1D25;color:#F0EBE3;font-family:'DM Sans',sans-serif;font-weight:700;padding:16px 36px;border-radius:4px;font-size:14px;box-shadow:0 10px 20px rgba(139,29,37,0.25);">
							<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
							Watch on YouTube
						</a>
						<a href="/blog/battle-of-okinawa/" style="text-decoration:none;color:#C8A86A;font-family:'DM Sans',sans-serif;font-weight:700;font-size:14px;letter-spacing:0.1em;text-transform:uppercase;border-bottom:1px solid #C8A86A;padding-bottom:2px;">Read Documented Story →</a>
					</div>
				</div>
			</div>

			<!-- Coming Soon Card -->
			<div style="background:#1C2C4F;border:1px solid rgba(255,255,255,0.12);padding:80px 48px;text-align:center;border-top:4px solid #C8A86A;border-radius:4px;">
				<p style="color:#C8A86A;font-family:'DM Sans',sans-serif;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.3em;margin:0 0 24px 0;">Upcoming Works</p>
				<h3 style="font-family:'DM Sans',sans-serif;font-size:32px;font-weight:800;color:#F0EBE3;margin:0 0 16px 0;letter-spacing:-0.02em;">New Documentaries in Production</h3>
				<p style="color:#A8B8C8;font-family:'Inter',serif;font-size:18px;line-height:1.8;margin:0 0 48px auto;max-width:560px;">From the Henoko base issue to the deep histories of Ryukyuan identity. New videos releasing every month.</p>
				<a href="https://www.youtube.com/@letsgokinawa" target="_blank" rel="noopener noreferrer" style="text-decoration:none;display:inline-flex;align-items:center;gap:12px;background:#8B1D25;color:#F0EBE3;font-family:'DM Sans',sans-serif;font-weight:700;padding:20px 56px;border-radius:4px;font-size:16px;">
					Follow the Channel
				</a>
			</div>

		</div>
	</section>

</Layout>
