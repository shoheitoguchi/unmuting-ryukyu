---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact | Unmuting Ryukyu">

	<!-- PAGE HEADER -->
	<section style="padding:72px 32px 56px;background:#1C2C4F;position:relative;overflow:hidden;border-bottom:4px solid #8B1D25;">
		<div style="position:absolute;top:0;left:0;width:5px;height:100%;background:#8B1D25;"></div>
		<div style="max-width:1100px;margin:0 auto;position:relative;z-index:1;">
			<p style="color:#8B1D25;font-family:'Noto Sans JP',sans-serif;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.3em;margin:0 0 16px 0;">Contact</p>
			<h1 style="font-family:'Shippori Mincho','Noto Serif JP',serif;font-size:clamp(36px,6vw,64px);font-weight:700;color:#F0EBE3;margin:0 0 16px 0;line-height:1.05;">Let's Talk</h1>
			<p style="color:#A8B8C8;font-family:'Noto Serif JP',serif;font-size:17px;line-height:1.8;margin:0;max-width:520px;">Interested in working together? Have a story that needs to be told? Reach out — I'd love to hear from you.</p>
		</div>
	</section>

	<!-- CONTACT INFO -->
	<section style="padding:80px 32px 96px;background:#F0EBE3;">
		<div style="max-width:760px;margin:0 auto;">

			<div style="background:#fff;border:1px solid #D0C5BA;border-top:4px solid #8B1D25;box-shadow:4px 4px 0px #1C2C4F;overflow:hidden;">

				<!-- Email -->
				<div style="padding:40px 48px;border-bottom:1px solid #E8E2D8;">
					<p style="color:#8B1D25;font-family:'Noto Sans JP',sans-serif;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.2em;margin:0 0 10px 0;">Email</p>
					<a href="mailto:letsgokinawa@gmail.com" style="text-decoration:none;font-family:'Shippori Mincho','Noto Serif JP',serif;font-size:22px;font-weight:600;color:#1C2C4F;letter-spacing:0.02em;">letsgokinawa@gmail.com</a>
				</div>

				<!-- Location -->
				<div style="padding:40px 48px;border-bottom:1px solid #E8E2D8;">
					<p style="color:#8B1D25;font-family:'Noto Sans JP',sans-serif;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.2em;margin:0 0 10px 0;">Based in</p>
					<p style="font-family:'Shippori Mincho','Noto Serif JP',serif;font-size:20px;font-weight:600;color:#1C2C4F;margin:0;">Okinawa, Japan</p>
					<p style="font-family:'Noto Serif JP',serif;font-size:14px;color:#4A3F3B;margin:6px 0 0 0;">Available worldwide for remote and international projects.</p>
				</div>

				<!-- Social -->
				<div style="padding:40px 48px;">
					<p style="color:#8B1D25;font-family:'Noto Sans JP',sans-serif;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.2em;margin:0 0 20px 0;">Social</p>
					<div style="display:flex;gap:12px;flex-wrap:wrap;">
						<a href="https://www.youtube.com/@letsgokinawa" target="_blank" rel="noopener noreferrer" style="text-decoration:none;background:#8B1D25;color:#F0EBE3;font-family:'Noto Sans JP',sans-serif;font-size:13px;font-weight:700;padding:10px 20px;border-radius:2px;letter-spacing:0.04em;">YouTube</a>
						<a href="https://www.instagram.com/unmutingryukyu/" target="_blank" rel="noopener noreferrer" style="text-decoration:none;border:1px solid #D0C5BA;color:#1C2C4F;font-family:'Noto Sans JP',sans-serif;font-size:13px;font-weight:500;padding:10px 20px;border-radius:2px;">Instagram</a>
						<a href="https://x.com/letsgokinawa" target="_blank" rel="noopener noreferrer" style="text-decoration:none;border:1px solid #D0C5BA;color:#1C2C4F;font-family:'Noto Sans JP',sans-serif;font-size:13px;font-weight:500;padding:10px 20px;border-radius:2px;">X / Twitter</a>
						<a href="https://www.tiktok.com/@letsgokinawa" target="_blank" rel="noopener noreferrer" style="text-decoration:none;border:1px solid #D0C5BA;color:#1C2C4F;font-family:'Noto Sans JP',sans-serif;font-size:13px;font-weight:500;padding:10px 20px;border-radius:2px;">TikTok</a>
					</div>
				</div>

			</div>

			<p style="color:#8B8078;font-family:'Noto Sans JP',sans-serif;font-size:13px;text-align:center;margin-top:32px;">Typically responds within 24–48 hours.</p>

		</div>
	</section>

</Layout>
