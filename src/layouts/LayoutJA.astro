---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "渡口翔平 — 映像編集者・ドキュメンタリー作家。失われゆく文化と記憶を、映像と言語で次世代へ。" } = Astro.props;
---

<!doctype html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="author" content="渡口翔平" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Shippori+Mincho:wght@400;500;600;700;800&family=Noto+Sans+JP:wght@300;400;500;700&family=DM+Sans:wght@400;500;700;800;900&display=swap" rel="stylesheet">
  <title>{title}</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg-deep:    #09131F;
      --bg-base:    #0D1B2A;
      --bg-card:    #0F2030;
      --cyan:       #22D3EE;
      --cyan-dim:   #0891B2;
      --cyan-pale:  rgba(34,211,238,0.10);
      --cyan-border:rgba(34,211,238,0.18);
      --text-hi:    #EFF8FF;
      --text-mid:   #94C4D8;
      --text-lo:    #4A7A96;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg-base);
      color: var(--text-hi);
      font-family: 'Noto Sans JP', sans-serif;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      line-height: 1.6;
    }

    /* ── HEADER ── */
    .ja-header {
      position: sticky;
      top: 0;
      z-index: 999;
      background: rgba(9,19,31,0.92);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--cyan-border);
    }

    .ja-header__inner {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 40px;
      height: 64px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .ja-logo {
      text-decoration: none;
      display: flex;
      align-items: baseline;
      gap: 12px;
    }

    .ja-logo__kanji {
      font-family: 'Shippori Mincho', serif;
      font-size: 17px;
      font-weight: 600;
      color: var(--cyan);
      letter-spacing: 0.1em;
    }

    .ja-logo__en {
      font-family: 'DM Sans', sans-serif;
      font-size: 11px;
      font-weight: 500;
      color: var(--text-lo);
      letter-spacing: 0.18em;
      text-transform: uppercase;
    }

    .ja-nav {
      display: flex;
      align-items: center;
      gap: 32px;
    }

    .ja-nav a {
      font-family: 'Noto Sans JP', sans-serif;
      font-size: 13px;
      font-weight: 400;
      color: var(--text-mid);
      text-decoration: none;
      letter-spacing: 0.04em;
      transition: color 0.2s;
    }

    .ja-nav a:hover { color: var(--cyan); }

    .ja-nav__cta {
      font-family: 'Noto Sans JP', sans-serif !important;
      font-size: 12px !important;
      font-weight: 700 !important;
      color: var(--bg-deep) !important;
      background: var(--cyan);
      padding: 9px 22px;
      border-radius: 3px;
      letter-spacing: 0.06em !important;
      transition: opacity 0.2s !important;
    }

    .ja-nav__cta:hover { opacity: 0.85 !important; }

    .ja-nav__lang {
      font-family: 'DM Sans', sans-serif !important;
      font-size: 11px !important;
      color: var(--text-lo) !important;
      border-left: 1px solid var(--cyan-border);
      padding-left: 24px !important;
      letter-spacing: 0.12em !important;
      text-transform: uppercase;
    }

    .ja-nav__lang:hover { color: var(--cyan) !important; }

    /* ── FOOTER ── */
    .ja-footer {
      background: var(--bg-deep);
      border-top: 1px solid var(--cyan-border);
      padding: 64px 40px 40px;
    }

    .ja-footer__inner {
      max-width: 1200px;
      margin: 0 auto;
    }

    .ja-footer__top {
      display: flex;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 48px;
      margin-bottom: 48px;
    }

    .ja-footer__brand p {
      font-family: 'Noto Sans JP', sans-serif;
      font-size: 13px;
      color: var(--text-lo);
      line-height: 2;
      margin-top: 16px;
      max-width: 300px;
    }

    .ja-footer__links {
      display: flex;
      gap: 56px;
      flex-wrap: wrap;
    }

    .ja-footer__col h4 {
      font-family: 'DM Sans', sans-serif;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--cyan);
      margin-bottom: 18px;
    }

    .ja-footer__col a {
      display: block;
      font-family: 'Noto Sans JP', sans-serif;
      font-size: 13px;
      color: var(--text-lo);
      text-decoration: none;
      margin-bottom: 10px;
      transition: color 0.2s;
    }

    .ja-footer__col a:hover { color: var(--cyan); }

    .ja-footer__bottom {
      border-top: 1px solid var(--cyan-border);
      padding-top: 24px;
      display: flex;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 12px;
    }

    .ja-footer__bottom p {
      font-family: 'DM Sans', sans-serif;
      font-size: 11px;
      color: var(--text-lo);
      letter-spacing: 0.04em;
    }

    @media (max-width: 768px) {
      .ja-header__inner { padding: 0 24px; }
      .ja-nav .nav-hide { display: none; }
      .ja-footer { padding: 48px 24px 32px; }
      .ja-footer__top { flex-direction: column; gap: 32px; }
    }
  </style>
</head>
<body>

  <header class="ja-header">
    <div class="ja-header__inner">
      <a href="/ja/" class="ja-logo">
        <span class="ja-logo__kanji">渡口 翔平</span>
        <span class="ja-logo__en">Shohei Toguchi</span>
      </a>
      <nav class="ja-nav">
        <a href="/ja/" class="nav-hide">ホーム</a>
        <a href="/ja/portfolio/" class="nav-hide">作品集</a>
        <a href="/ja/about/" class="nav-hide">について</a>
        <a href="/ja/contact/" class="ja-nav__cta">お問い合わせ</a>
        <a href="/en/" class="ja-nav__lang">EN</a>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="ja-footer">
    <div class="ja-footer__inner">
      <div class="ja-footer__top">
        <div class="ja-footer__brand">
          <div>
            <span style="font-family:'Shippori Mincho',serif;font-size:18px;font-weight:600;color:var(--cyan);letter-spacing:0.1em;">渡口 翔平</span>
          </div>
          <p>映像と言語で、失われゆく文化を記録する。</p>
        </div>
        <div class="ja-footer__links">
          <div class="ja-footer__col">
            <h4>Pages</h4>
            <a href="/ja/">ホーム</a>
            <a href="/ja/portfolio/">作品集</a>
            <a href="/ja/about/">について</a>
            <a href="/ja/contact/">お問い合わせ</a>
          </div>
          <div class="ja-footer__col">
            <h4>SNS</h4>
            <a href="https://www.youtube.com/@letsgokinawa" target="_blank" rel="noopener">YouTube</a>
            <a href="https://www.instagram.com/unmutingryukyu/" target="_blank" rel="noopener">Instagram</a>
            <a href="https://x.com/letsgokinawa" target="_blank" rel="noopener">X / Twitter</a>
          </div>
          <div class="ja-footer__col">
            <h4>Language</h4>
            <a href="/ja/">日本語</a>
            <a href="/en/">English</a>
            <a href="/zh/">中文（準備中）</a>
          </div>
        </div>
      </div>
      <div class="ja-footer__bottom">
        <p>&copy; 2026 渡口翔平. All rights reserved.</p>
        <p>Okinawa, Japan</p>
      </div>
    </div>
  </footer>

</body>
</html>
