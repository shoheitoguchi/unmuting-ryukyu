---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "渡口翔平 — ドキュメンタリー映像作家・動画編集者。沖縄・琉球の物語を世界へ。" } = Astro.props;
---

<!doctype html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="author" content="渡口翔平" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&family=Noto+Sans+JP:wght@300;400;500;700&family=Noto+Serif+JP:wght@400;500;700&display=swap" rel="stylesheet">
  <title>{title}</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    body {
      margin: 0;
      padding: 0;
      font-family: 'Noto Sans JP', sans-serif;
      background: #F5FAFB;
      color: #1A3A4A;
      -webkit-font-smoothing: antialiased;
    }

    /* ── Header ── */
    .site-header {
      position: sticky;
      top: 0;
      z-index: 999;
      background: rgba(26,58,74,0.97);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(126,200,227,0.15);
      padding: 0 40px;
    }

    .header-inner {
      max-width: 1200px;
      margin: 0 auto;
      display: flex;
      justify-content: space-between;
      align-items: center;
      height: 68px;
    }

    .site-logo {
      text-decoration: none;
      display: flex;
      align-items: baseline;
      gap: 10px;
    }

    .logo-ja {
      font-family: 'Noto Serif JP', serif;
      font-size: 17px;
      font-weight: 700;
      color: #7EC8E3;
      letter-spacing: 0.08em;
    }

    .logo-en {
      font-family: 'DM Sans', sans-serif;
      font-size: 13px;
      font-weight: 400;
      color: rgba(245,250,251,0.45);
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .site-nav {
      display: flex;
      align-items: center;
      gap: 28px;
    }

    .site-nav a {
      text-decoration: none;
      color: rgba(245,250,251,0.75);
      font-family: 'Noto Sans JP', sans-serif;
      font-size: 13px;
      font-weight: 400;
      letter-spacing: 0.05em;
      transition: color 0.2s;
    }

    .site-nav a:hover { color: #7EC8E3; }

    .nav-cta {
      text-decoration: none;
      background: #7EC8E3;
      color: #1A3A4A !important;
      font-family: 'Noto Sans JP', sans-serif;
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.08em;
      padding: 10px 20px;
      border-radius: 3px;
      transition: background 0.2s, transform 0.2s !important;
    }

    .nav-cta:hover {
      background: #5BAAC8 !important;
      transform: translateY(-1px);
    }

    .lang-switch {
      color: rgba(245,250,251,0.35) !important;
      font-size: 12px !important;
      border-left: 1px solid rgba(126,200,227,0.2);
      padding-left: 24px !important;
      font-family: 'DM Sans', sans-serif !important;
    }

    .lang-switch:hover { color: #7EC8E3 !important; }

    /* ── Footer ── */
    .site-footer {
      background: #1A3A4A;
      padding: 72px 40px 40px;
      border-top: 1px solid rgba(126,200,227,0.12);
    }

    .footer-inner {
      max-width: 1200px;
      margin: 0 auto;
    }

    .footer-top {
      display: flex;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 56px;
      margin-bottom: 56px;
    }

    .footer-brand { max-width: 360px; }

    .footer-desc {
      color: rgba(245,250,251,0.5);
      font-family: 'Noto Sans JP', sans-serif;
      font-size: 13px;
      line-height: 2;
      margin: 16px 0 0 0;
    }

    .footer-accent {
      width: 40px;
      height: 2px;
      background: #7EC8E3;
      margin-top: 20px;
    }

    .footer-links { display: flex; gap: 64px; flex-wrap: wrap; }

    .footer-col h4 {
      color: #7EC8E3;
      font-family: 'Noto Sans JP', sans-serif;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      margin: 0 0 20px 0;
    }

    .footer-col a {
      display: block;
      text-decoration: none;
      color: rgba(245,250,251,0.5);
      font-family: 'Noto Sans JP', sans-serif;
      font-size: 13px;
      margin-bottom: 12px;
      transition: color 0.2s;
    }

    .footer-col a:hover { color: #7EC8E3; }

    .footer-bottom {
      border-top: 1px solid rgba(126,200,227,0.10);
      padding-top: 28px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 16px;
    }

    .footer-bottom p {
      color: rgba(245,250,251,0.28);
      font-family: 'Noto Sans JP', sans-serif;
      font-size: 12px;
      margin: 0;
    }

    .footer-bottom a {
      color: rgba(245,250,251,0.50);
      text-decoration: none;
    }

    @media (max-width: 768px) {
      .site-nav { gap: 16px; }
      .site-nav .nav-hide { display: none; }
      .footer-top { flex-direction: column; gap: 40px; }
      .footer-links { gap: 40px; }
    }
  </style>
</head>
<body>

  <!-- HEADER -->
  <header class="site-header">
    <div class="header-inner">
      <a href="/ja/" class="site-logo">
        <span class="logo-ja">渡口翔平</span>
        <span class="logo-en">Unmuting Ryukyu</span>
      </a>
      <nav class="site-nav">
        <a href="/ja/" class="nav-hide">ホーム</a>
        <a href="/ja/portfolio/" class="nav-hide">ポートフォリオ</a>
        <a href="/ja/videos/" class="nav-hide">動画</a>
        <a href="/ja/blog/" class="nav-hide">ブログ</a>
        <a href="/ja/about/">自己紹介</a>
        <a href="/ja/contact/" class="nav-cta">お問い合わせ</a>
        <a href="/en/" class="lang-switch">EN</a>
      </nav>
    </div>
  </header>

  <!-- CONTENT -->
  <main>
    <slot />
  </main>

  <!-- FOOTER -->
  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-top">
        <div class="footer-brand">
          <div>
            <span style="font-family:'Noto Serif JP',serif;font-size:20px;font-weight:700;color:#7EC8E3;letter-spacing:0.08em;">渡口翔平</span>
            <span style="font-family:'DM Sans',sans-serif;font-size:13px;font-weight:400;color:rgba(245,250,251,0.4);letter-spacing:0.06em;text-transform:uppercase;margin-left:10px;">Unmuting Ryukyu</span>
          </div>
          <p class="footer-desc">沖縄・琉球の歴史と文化を<br/>ドキュメンタリー映像で世界へ発信。</p>
          <div class="footer-accent"></div>
        </div>
        <div class="footer-links">
          <div class="footer-col">
            <h4>コンテンツ</h4>
            <a href="/ja/portfolio/">ポートフォリオ</a>
            <a href="/ja/videos/">動画一覧</a>
            <a href="/ja/blog/">ブログ</a>
          </div>
          <div class="footer-col">
            <h4>プロフィール</h4>
            <a href="/ja/about/">渡口翔平について</a>
            <a href="/ja/services/">サービス</a>
            <a href="/ja/contact/">お問い合わせ</a>
          </div>
          <div class="footer-col">
            <h4>SNS</h4>
            <a href="https://www.youtube.com/@letsgokinawa" target="_blank" rel="noopener">YouTube</a>
            <a href="https://www.instagram.com/unmutingryukyu/" target="_blank" rel="noopener">Instagram</a>
            <a href="https://x.com/letsgokinawa" target="_blank" rel="noopener">X / Twitter</a>
          </div>
          <div class="footer-col">
            <h4>言語</h4>
            <a href="/ja/">日本語</a>
            <a href="/en/">English</a>
            <a href="/zh/">中文（準備中）</a>
          </div>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; 2026 渡口翔平 / Unmuting Ryukyu. All rights reserved.</p>
        <p><a href="/ja/about/">渡口翔平</a> によるドキュメンタリープロジェクト</p>
      </div>
    </div>
  </footer>

</body>
</html>
