---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Unmuting Ryukyu — Revealing the hidden stories of Okinawa's struggle, culture, and resilience through documentary filmmaking." />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="author" content="Shohei Toguchi" />
		<meta property="og:title" content="Unmuting Ryukyu" />
		<meta property="og:description" content="Documentary filmmaker revealing Okinawa's untold stories." />
		<meta property="og:type" content="website" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=Noto+Sans+JP:wght@100..900&family=Shippori+Mincho:wght@400;500;600;700;800&display=swap" rel="stylesheet">
		<title>{title}</title>
	</head>
	<body style="margin:0;padding:0;font-family:'Inter', sans-serif;background:#F0EBE3;color:#4A3F3B;-webkit-font-smoothing:antialiased;-moz-osx-font-smoothing:grayscale;">

		<!-- HEADER -->
		<header style="position:sticky;top:0;z-index:999;background:rgba(28,44,79,0.97);backdrop-filter:blur(12px);border-bottom:1px solid rgba(255,255,255,0.1);padding:0 32px;">
			<div style="max-width:1200px;margin:0 auto;display:flex;justify-content:space-between;align-items:center;height:72px;">
				<a href="/" style="text-decoration:none;display:flex;align-items:baseline;gap:6px;">
					<span style="font-family:'DM Sans', sans-serif;font-size:20px;font-weight:800;color:#8B1D25;letter-spacing:0.04em;text-transform:uppercase;">Unmuting</span>
					<span style="font-family:'DM Sans', sans-serif;font-size:20px;font-weight:400;color:#C8A86A;letter-spacing:0.04em;text-transform:uppercase;">Ryukyu</span>
				</a>
				<nav style="display:flex;align-items:center;gap:32px;">
					<a href="/" style="text-decoration:none;color:#F0EBE3;font-family:'DM Sans', sans-serif;font-size:14px;font-weight:500;letter-spacing:0.02em;transition:color 0.2s;">Home</a>
					<a href="/videos/" style="text-decoration:none;color:#F0EBE3;font-family:'DM Sans', sans-serif;font-size:14px;font-weight:500;letter-spacing:0.02em;transition:color 0.2s;">Videos</a>
					<a href="/blog/" style="text-decoration:none;color:#F0EBE3;font-family:'DM Sans', sans-serif;font-size:14px;font-weight:500;letter-spacing:0.02em;transition:color 0.2s;">Blog</a>
					<a href="/services/" style="text-decoration:none;color:#F0EBE3;font-family:'DM Sans', sans-serif;font-size:14px;font-weight:500;letter-spacing:0.02em;transition:color 0.2s;">Services</a>
					<a href="/about/" style="text-decoration:none;color:#F0EBE3;font-family:'DM Sans', sans-serif;font-size:14px;font-weight:500;letter-spacing:0.02em;transition:color 0.2s;">About</a>
					<a href="https://www.youtube.com/@letsgokinawa" target="_blank" rel="noopener noreferrer" style="text-decoration:none;color:#C8A86A;font-family:'DM Sans', sans-serif;font-size:14px;font-weight:700;letter-spacing:0.02em;display:inline-flex;align-items:center;gap:8px;border-bottom:1px solid #C8A86A;padding-bottom:2px;">
						YouTube
					</a>
				</nav>
			</div>
		</header>

		<main>
			<slot />
		</main>

		<!-- FOOTER -->
		<footer style="background:#1C2C4F;padding:80px 32px 48px;border-top:1px solid rgba(255,255,255,0.1);">
			<div style="max-width:1200px;margin:0 auto;">
				<div style="display:flex;justify-content:space-between;flex-wrap:wrap;gap:64px;margin-bottom:64px;">
					<div style="max-width:400px;">
						<div style="margin-bottom:24px;">
							<span style="font-family:'DM Sans', sans-serif;font-size:22px;font-weight:800;color:#8B1D25;letter-spacing:0.04em;text-transform:uppercase;">Unmuting</span>
							<span style="font-family:'DM Sans', sans-serif;font-size:22px;font-weight:400;color:#C8A86A;letter-spacing:0.04em;text-transform:uppercase;"> Ryukyu</span>
						</div>
						<p style="color:#A8B8C8;font-family:'Inter', sans-serif;font-size:15px;line-height:1.8;margin:0 0 24px 0;">Revealing the hidden stories of Okinawa's struggle, culture, and resilience through documentary filmmaking.</p>
						<div style="width:48px;height:2px;background:#8B1D25;"></div>
					</div>
					<div style="display:flex;gap:72px;flex-wrap:wrap;">
						<div>
							<p style="color:#C8A86A;font-family:'DM Sans', sans-serif;font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:0.15em;margin:0 0 24px 0;">Navigate</p>
							<a href="/" style="display:block;text-decoration:none;color:#A8B8C8;font-family:'Inter', sans-serif;font-size:14px;margin-bottom:14px;">Home</a>
							<a href="/videos/" style="display:block;text-decoration:none;color:#A8B8C8;font-family:'Inter', sans-serif;font-size:14px;margin-bottom:14px;">Videos</a>
							<a href="/blog/" style="display:block;text-decoration:none;color:#A8B8C8;font-family:'Inter', sans-serif;font-size:14px;margin-bottom:14px;">Blog</a>
							<a href="/services/" style="display:block;text-decoration:none;color:#A8B8C8;font-family:'Inter', sans-serif;font-size:14px;margin-bottom:14px;">Services</a>
							<a href="/about/" style="display:block;text-decoration:none;color:#A8B8C8;font-family:'Inter', sans-serif;font-size:14px;">About</a>
						</div>
						<div>
							<p style="color:#C8A86A;font-family:'DM Sans', sans-serif;font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:0.15em;margin:0 0 24px 0;">Connect</p>
							<a href="https://www.youtube.com/@letsgokinawa" target="_blank" rel="noopener noreferrer" style="display:block;text-decoration:none;color:#A8B8C8;font-family:'Inter', sans-serif;font-size:14px;margin-bottom:14px;">YouTube</a>
							<a href="https://www.instagram.com/unmutingryukyu/" target="_blank" rel="noopener noreferrer" style="display:block;text-decoration:none;color:#A8B8C8;font-family:'Inter', sans-serif;font-size:14px;margin-bottom:14px;">Instagram</a>
							<a href="https://x.com/letsgokinawa" target="_blank" rel="noopener noreferrer" style="display:block;text-decoration:none;color:#A8B8C8;font-family:'Inter', sans-serif;font-size:14px;margin-bottom:14px;">X / Twitter</a>
							<a href="https://www.tiktok.com/@letsgokinawa" target="_blank" rel="noopener noreferrer" style="display:block;text-decoration:none;color:#A8B8C8;font-family:'Inter', sans-serif;font-size:14px;">TikTok</a>
						</div>
						<div>
							<p style="color:#C8A86A;font-family:'DM Sans', sans-serif;font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:0.15em;margin:0 0 24px 0;">Business</p>
							<a href="/services/" style="display:block;text-decoration:none;color:#A8B8C8;font-family:'Inter', sans-serif;font-size:14px;margin-bottom:14px;">Services</a>
							<a href="/contact/" style="display:block;text-decoration:none;color:#A8B8C8;font-family:'Inter', sans-serif;font-size:14px;">Contact</a>
						</div>
					</div>
				</div>
				<div style="border-top:1px solid rgba(255,255,255,0.1);padding-top:32px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:20px;">
					<p style="color:#A8B8C8;font-family:'Inter', sans-serif;font-size:13px;margin:0;">&copy; 2026 Unmuting Ryukyu. All rights reserved.</p>
					<p style="color:#A8B8C8;font-family:'Inter', sans-serif;font-size:13px;margin:0;">A documentary project by <a href="/about/" style="color:#F0EBE3;text-decoration:none;">Shohei Toguchi</a></p>
				</div>
			</div>
		</footer>

	</body>
</html>
